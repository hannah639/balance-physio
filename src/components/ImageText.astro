---
const {
	eyebrow,
	heading,
	highlight,
	reverse = false,
	altBg = false,
	image,
	imageAlt = '',
	imagePosition,
	placeholderLabel = 'Image placeholder',
	youtubeId,
	autoplay = false,
	collage,
	mapEmbedUrl,
} = Astro.props;

const classes = ['image-text'];
if (reverse) classes.push('reverse');
if (altBg) classes.push('alt-bg');

const mediaClasses = ['image-text-media'];
if (youtubeId && autoplay) mediaClasses.push('image-text-media--video');

const imgStyle = imagePosition ? `object-position: ${imagePosition};` : undefined;

// Build a YouTube thumbnail URL if a videoId is provided.
// If a custom `image` is also supplied, prefer it, useful when the auto-generated
// YouTube thumbnail isn't a good fit and we want branded artwork behind the play button.
const thumbUrl = image || (youtubeId ? `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg` : null);

// Build an embed URL with autoplay params when autoplay mode is requested.
// mute=1 is required by browsers for autoplay to work without user interaction.
// playsinline=1 keeps the video inline on mobile rather than going fullscreen.
const embedUrl = youtubeId && autoplay
	? `https://www.youtube.com/embed/${youtubeId}?autoplay=1&mute=1&controls=1&modestbranding=1&rel=0&playsinline=1`
	: null;
---
<section class={classes.join(' ')}>
	<div class="image-text-inner">
		<div class={mediaClasses.join(' ')}>
			{mapEmbedUrl ? (
				<iframe
					src={mapEmbedUrl}
					title={imageAlt || 'Location map'}
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					allowfullscreen
					frameborder="0"
				></iframe>
			) : youtubeId && autoplay ? (
				<iframe
					src={embedUrl}
					title={imageAlt || 'Video'}
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
					allowfullscreen
					loading="lazy"
					frameborder="0"
				></iframe>
			) : youtubeId ? (
				<button class="video-trigger" data-youtube={youtubeId} aria-label="Play video">
					<img src={thumbUrl} alt={imageAlt || 'Play video'} />
					<span class="play-btn"><span class="play-icon">▶</span></span>
				</button>
			) : image ? (
				<img src={image} alt={imageAlt} style={imgStyle} />
			) : collage && collage.length ? (
				<div class="media-collage">
					{collage.map((item) => (
						<img src={item.src} alt={item.alt || ''} />
					))}
				</div>
			) : (
				<div class="media-placeholder">{placeholderLabel}</div>
			)}
		</div>
		<div class="image-text-content">
			{eyebrow && <div class="eyebrow">{eyebrow}</div>}
			{heading && (
				<h2>
					{highlight ? <>{heading}{' '}<span class="highlight">{highlight}</span></> : heading}
				</h2>
			)}
			<slot />
		</div>
	</div>
</section>
