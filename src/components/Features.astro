---
const services = [
	{ title: 'Physiotherapy', href: '/service/physiotherapy', bg: '/archery.jpg' },
	{ title: 'Sports Physiotherapy', href: '/service/sports-physiotherapy', bg: '/hockey.jpg' },
	{ title: 'Osteopathy', href: '/service/osteopathy', bg: '/osteopathy.jpg' },
	{ title: 'Sports Massage', href: '/service/sports-massage', bg: '/massage.jpg' },
	{ title: 'Shockwave Therapy', href: '/service/shockwave-therapy', bg: '/shockwave.jpg' },
	{ title: 'Prehab Class', href: '/service/prehab-class', bg: '/prehab.jpg' },
	{ title: 'Neurological Rehabilitation', href: '/service/neurological-rehabilitation', bg: '/neuro-rehab.jpg' },
	{ title: 'Vojta Therapy', href: '/service/vojta-therapy', bg: '/vojta.jpg' },
	{ title: "Women's Health", href: '/service/womens-health', bg: '/womens-health.jpg' },
	{ title: "Men's Health", href: '/service/mens-health', bg: '/mens-health.jpg' },
	{ title: 'Podiatry', href: '/service/podiatry', bg: '/podiatry.jpg' },
	{ title: 'Strength & Conditioning', href: '/service/strength-conditioning', bg: '/strength-conditioning.jpg' },
	{ title: 'LIFT — Weight Training Club', href: '/service/lift-weight-training-club', bg: '/lift.jpg' },
	{ title: 'Bike Fitting', href: '/service/bike-fitting-running-analysis', bg: '/cycling.jpg' },
	{ title: 'Running Analysis', href: '/service/bike-fitting-running-analysis', bg: '/running.jpg' },
	{ title: 'Hydrotherapy', href: '/service/hydrotherapy', bg: '/hydrotherapy.jpg' },
	{ title: 'Psychological Wellness', href: '/service/psychological-wellness', bg: '/psychological-wellness.jpg' },
	{ title: 'Anti-Gravity Treadmill', href: '/service/anti-gravity-treadmill', bg: '/antigravity.webp' },
	{ title: 'Ergonomics', href: '/service/ergonomics', bg: '/ergonomics.jpg' },
	{ title: 'TMJ & Jaw Pain', href: '/service/tmj-and-jaw-pain', bg: '/tmj.jpg' },
	{ title: 'Physiotherapy Prescribing', href: '/service/physiotherapy-prescribing', bg: '/prescribing.jpg' },
];

function gradientFor(title) {
	var hash = 0;
	for (var i = 0; i < title.length; i++) hash = (hash << 5) - hash + title.charCodeAt(i);
	var hue = Math.abs(hash) % 360;
	return `linear-gradient(135deg, hsl(${hue}, 55%, 35%) 0%, hsl(${(hue + 50) % 360}, 60%, 22%) 100%)`;
}
---

<section class="features">
	<div class="container">
		<div class="section-header">
			<div class="hero-badge"><span class="dot"></span> Our Services</div>
			<h2><span class="highlight">What we</span> offer.</h2>
			<p>Relieving pain, restoring function, exploring movement, enhancing health & performance</p>
		</div>
		<div class="feature-list">
			{services.map((s) => (
				<a
					href={s.href}
					class="feature-card"
					style={s.bg ? `` : `background: ${gradientFor(s.title)};`}
				>
					{s.bg && <div class="feature-card-bg" style={`background-image: url('${s.bg}');`} />}
					<div class="feature-card-overlay"></div>
					<div class="feature-card-content">
						<div class="service-label">Service</div>
						<h3>{s.title}</h3>
					</div>
				</a>
			))}
		</div>
		<div class="feature-nav">
			<button class="feature-nav-btn" onclick="document.querySelector('.bp-page .feature-list').scrollBy({left:-344,behavior:'smooth'})">&larr;</button>
			<button class="feature-nav-btn" onclick="document.querySelector('.bp-page .feature-list').scrollBy({left:344,behavior:'smooth'})">&rarr;</button>
		</div>
	</div>
</section>
