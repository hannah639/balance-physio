---
import Layout from '../layouts/Layout.astro';
import PageHero from './PageHero.astro';
import ImageText from './ImageText.astro';
import PhotoMarquee from './PhotoMarquee.astro';
import BookingCTA from './BookingCTA.astro';

const {
	title,
	highlight,
	heroSubtitle,
	breadcrumb,
	seoTitle,
	seoDescription,
	intro,          // array of paragraphs for intro block
	introYoutubeId, // optional YouTube video ID for lightbox on intro block
	introImage,     // optional image URL for intro block
	whenHeading = 'When to consider',
	whenHighlight = 'this service',
	whenIntro,      // string
	whenList,       // array
	whenOutro,      // optional closing paragraph rendered below the list
	whenImage,      // optional image URL
	howHeading = 'How we',
	howHighlight = 'treat',
	howIntro,
	howList,
	howImage,       // optional image URL
	whoHeading = 'Who we',
	whoHighlight = 'help',
	whoIntro,
	whoList,
	whoImage,       // optional image URL
	faqs = [],
	marqueeImages, // optional array of {src, alt} — defaults to placeholder set
	marqueeSpeed = 45,
} = Astro.props;

// Default placeholder image set used when a page doesn't supply its own photos
const defaultPlaceholders = [
	{ src: '/placeholders/01.jpg', alt: '' },
	{ src: '/placeholders/02.jpg', alt: '' },
	{ src: '/placeholders/03.jpg', alt: '' },
	{ src: '/placeholders/04.jpg', alt: '' },
	{ src: '/placeholders/05.jpg', alt: '' },
	{ src: '/placeholders/06.jpg', alt: '' },
	{ src: '/placeholders/07.jpg', alt: '' },
	{ src: '/placeholders/08.jpg', alt: '' },
];
const photos = marqueeImages && marqueeImages.length > 0 ? marqueeImages : defaultPlaceholders;
---
<Layout title={seoTitle} description={seoDescription}>
	<PageHero title={title} highlight={highlight} subtitle={heroSubtitle} breadcrumb={breadcrumb} />

	<PhotoMarquee images={photos} heightPx={140} speedSeconds={marqueeSpeed} />

	<slot name="after-hero" />

	{intro && intro.length > 0 && (
		<ImageText
			eyebrow="Our approach"
			heading="Evidence-led"
			highlight="care"
			placeholderLabel="Treatment in progress"
			youtubeId={introYoutubeId}
			image={introImage}
		>
			{intro.map((p) => <p>{p}</p>)}
		</ImageText>
	)}

	{whenList && whenList.length > 0 && (
		<ImageText
			eyebrow="Symptoms"
			heading={whenHeading}
			highlight={whenHighlight}
			reverse
			altBg
			placeholderLabel="Assessment"
			image={whenImage}
		>
			{whenIntro && <p>{whenIntro}</p>}
			<ul>
				{whenList.map((item) => <li>{item}</li>)}
			</ul>
			{whenOutro && <p>{whenOutro}</p>}
		</ImageText>
	)}

	{howList && howList.length > 0 && (
		<ImageText
			eyebrow="Treatment"
			heading={howHeading}
			highlight={howHighlight}
			placeholderLabel="Treatment session"
			image={howImage}
		>
			{howIntro && <p>{howIntro}</p>}
			<ul>
				{howList.map((item) => <li>{item}</li>)}
			</ul>
		</ImageText>
	)}

	{whoList && whoList.length > 0 && (
		<ImageText
			eyebrow="Who we help"
			heading={whoHeading}
			highlight={whoHighlight}
			reverse
			altBg
			placeholderLabel="Our patients"
			image={whoImage}
		>
			{whoIntro && <p>{whoIntro}</p>}
			<ul>
				{whoList.map((item) => <li>{item}</li>)}
			</ul>
		</ImageText>
	)}

	<slot name="before-faq" />

	{faqs.length > 0 && (
		<section class="faq-section">
			<div class="container">
				<div class="section-header">
					<h2>Frequently Asked Questions</h2>
				</div>
				<div class="faq-list">
					{faqs.map((item) => (
						<details class="faq-item">
							<summary>{item.q}</summary>
							<div class="answer">{item.a}</div>
						</details>
					))}
				</div>
			</div>
		</section>
	)}

	<BookingCTA />
</Layout>
