---
import Layout from '../layouts/Layout.astro';
import PageHero from './PageHero.astro';
import ImageText from './ImageText.astro';
import BookingCTA from './BookingCTA.astro';

const {
	title,
	highlight,
	heroSubtitle,
	breadcrumb,
	seoTitle,
	seoDescription,
	intro,
	symptomsHeading = 'When to get it',
	symptomsHighlight = 'checked',
	symptomsIntro,
	symptomsList,
	treatmentHeading = 'How we',
	treatmentHighlight = 'treat it',
	treatmentIntro,
	treatmentList,
	whoHeading = 'Who we',
	whoHighlight = 'help',
	whoIntro,
	whoList,
	faqs = [],
} = Astro.props;
---
<Layout title={seoTitle} description={seoDescription}>
	<PageHero title={title} highlight={highlight} subtitle={heroSubtitle} breadcrumb={breadcrumb} />

	{intro && intro.length > 0 && (
		<ImageText
			eyebrow="Our approach"
			heading="Expert clinical"
			highlight="care"
			placeholderLabel="Clinical assessment"
		>
			{intro.map((p) => <p set:html={p} />)}
		</ImageText>
	)}

	{symptomsList && symptomsList.length > 0 && (
		<ImageText
			eyebrow="Symptoms"
			heading={symptomsHeading}
			highlight={symptomsHighlight}
			reverse
			altBg
			placeholderLabel="Symptom assessment"
		>
			{symptomsIntro && <p>{symptomsIntro}</p>}
			<ul>
				{symptomsList.map((item) => <li>{item}</li>)}
			</ul>
		</ImageText>
	)}

	{treatmentList && treatmentList.length > 0 && (
		<ImageText
			eyebrow="Treatment"
			heading={treatmentHeading}
			highlight={treatmentHighlight}
			placeholderLabel="Treatment approach"
		>
			{treatmentIntro && <p>{treatmentIntro}</p>}
			<ul>
				{treatmentList.map((item) => <li>{item}</li>)}
			</ul>
		</ImageText>
	)}

	{whoList && whoList.length > 0 && (
		<ImageText
			eyebrow="Who we help"
			heading={whoHeading}
			highlight={whoHighlight}
			reverse
			altBg
			placeholderLabel="Our patients"
		>
			{whoIntro && <p>{whoIntro}</p>}
			<ul>
				{whoList.map((item) => <li>{item}</li>)}
			</ul>
		</ImageText>
	)}

	{faqs.length > 0 && (
		<section class="faq-section">
			<div class="container">
				<div class="section-header">
					<h2>Frequently Asked Questions</h2>
				</div>
				<div class="faq-list">
					{faqs.map((item) => (
						<details class="faq-item">
							<summary>{item.q}</summary>
							<div class="answer">{item.a}</div>
						</details>
					))}
				</div>
			</div>
		</section>
	)}

	<BookingCTA />
</Layout>
