---
import Layout from '../layouts/Layout.astro';
import PageHero from './PageHero.astro';
import ImageText from './ImageText.astro';
import BookingCTA from './BookingCTA.astro';

const {
	title,
	highlight,
	heroSubtitle,
	breadcrumb,
	seoTitle,
	seoDescription,
	intro,
	symptomsHeading = 'When to get it',
	symptomsHighlight = 'checked',
	symptomsIntro,
	symptomsList,
	treatmentHeading = 'How we',
	treatmentHighlight = 'treat it',
	treatmentIntro,
	treatmentList,
	whoHeading = 'Who we',
	whoHighlight = 'help',
	whoIntro,
	whoList,
	faqs = [],
} = Astro.props;
---
<Layout title={seoTitle} description={seoDescription}>
	<PageHero title={title} highlight={highlight} subtitle={heroSubtitle} breadcrumb={breadcrumb} />

	{intro && intro.length > 0 && (
		<ImageText
			eyebrow="Our approach"
			heading="Expert clinical"
			highlight="care"
			altBg
			placeholderLabel="Clinical assessment"
		>
			{intro.map((p) => <p set:html={p} />)}
		</ImageText>
	)}

	{((symptomsList && symptomsList.length > 0) || (treatmentList && treatmentList.length > 0)) && (
		<section class="text-grid text-grid--light">
			<div class="text-grid-inner">
				{symptomsList && symptomsList.length > 0 && (
					<div class="image-text-content text-grid-cell">
						<div class="eyebrow">Symptoms</div>
						<h2>{symptomsHeading} <span class="highlight">{symptomsHighlight}</span></h2>
						{symptomsIntro && <p>{symptomsIntro}</p>}
						<ul>
							{symptomsList.map((item) => <li>{item}</li>)}
						</ul>
					</div>
				)}
				{treatmentList && treatmentList.length > 0 && (
					<div class="image-text-content text-grid-cell text-grid-cell--treatment">
						<div class="eyebrow">Treatment</div>
						<h2>{treatmentHeading} <span class="highlight">{treatmentHighlight}</span></h2>
						{treatmentIntro && <p>{treatmentIntro}</p>}
						<ul>
							{treatmentList.map((item) => <li>{item}</li>)}
						</ul>
					</div>
				)}
			</div>
		</section>
	)}

	{whoList && whoList.length > 0 && (
		<ImageText
			eyebrow="Who we help"
			heading={whoHeading}
			highlight={whoHighlight}
			reverse
			altBg
			placeholderLabel="Our patients"
		>
			{whoIntro && <p>{whoIntro}</p>}
			<ul>
				{whoList.map((item) => <li>{item}</li>)}
			</ul>
		</ImageText>
	)}

	{faqs.length > 0 && (
		<section class="faq-section">
			<div class="container">
				<div class="section-header">
					<h2>Frequently Asked Questions</h2>
				</div>
				<div class="faq-list">
					{faqs.map((item) => (
						<details class="faq-item">
							<summary>{item.q}</summary>
							<div class="answer">{item.a}</div>
						</details>
					))}
				</div>
			</div>
		</section>
	)}

	<BookingCTA />
</Layout>
