---
import { team, initials } from '../data/team.js';

const {
	featured = false,
	heading = 'Meet Our Team',
	subheading = 'We have 25+ professionals under one roof waiting to help you move, recover and perform.',
} = Astro.props;

// Homepage shows a featured subset; full team page shows everyone
const members = featured ? team.slice(0, 8) : team;

// Deterministic gradient per name so every card feels unique
function gradientFor(name) {
	var hash = 0;
	for (var i = 0; i < name.length; i++) hash = (hash << 5) - hash + name.charCodeAt(i);
	var hue = Math.abs(hash) % 360;
	return `linear-gradient(135deg, hsl(${hue}, 45%, 42%) 0%, hsl(${(hue + 40) % 360}, 40%, 28%) 100%)`;
}
---

<section class="team">
	<div class="container">
		<div class="section-header">
			<h2>{heading}</h2>
			<p>{subheading}</p>
		</div>
		<div class="team-grid">
			{members.map((member) => (
				<div class="team-card">
					<div class="team-photo-wrap" style={`background: ${gradientFor(member.name)};`}>
						<span class="team-initials">{initials(member.name)}</span>
					</div>
					<a href={member.profileUrl || '#'} class="team-link-btn" target="_blank" rel="noopener" aria-label={`View ${member.name}'s bio`}>&#8599;</a>
					<div class="info">
						<h3>{member.name}</h3>
						<span class="role">{member.role}</span>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.team-photo-wrap {
		width: 100%;
		height: 300px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.team-initials {
		color: #ffffff;
		font-size: 72px;
		font-weight: 800;
		letter-spacing: -2px;
		font-family: 'Inter', sans-serif;
	}
</style>
