---
import { sanityClient, urlFor } from '../lib/sanity.js';

const teamMembers = await sanityClient.fetch(
  `*[_type == "teamMember"] | order(order asc) {
    _id,
    name,
    role,
    photo,
    profileUrl
  }`
);
---

<section class="team">
	<div class="container">
		<div class="section-header">
			<h2>Meet Our Team</h2>
			<p>We have 25 professionals under one roof waiting to impart their knowledge to improve your wellness.</p>
		</div>
		<div class="team-grid">
			{teamMembers.map((member) => (
				<div class="team-card">
					<img src={urlFor(member.photo).width(600).height(600).url()} alt={member.name} class="team-photo" />
					<a href={member.profileUrl || '#'} class="team-link-btn">&#8599;</a>
					<div class="info">
						<h3>{member.name}</h3>
						<span class="role">{member.role}</span>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
