---
import { team, initials, gradientFor } from '../data/team.js';

const {
	featured = false,
	sliderRow = false,
	centered = false,
	heading = 'Meet Our Team',
	subheading = 'We have 27 professionals under one roof waiting to help you move, recover and perform.',
	members: customMembers = null,
} = Astro.props;

// Default lists exclude wellness-only members (Sally, Kat, Richard) — they only appear on the Wellness page.
// `customMembers` lets the Wellness page pass in its own filtered list (the three wellness specialists).
const baseTeam = team.filter((m) => !m.wellness);
const members = customMembers
	? customMembers
	: featured
		? baseTeam.slice(0, 8)
		: baseTeam;
---

<section class={`team ${sliderRow ? 'team-slider-mode' : ''} ${centered ? 'team-centered-mode' : ''}`}>
	<div class="container">
		<div class="section-header">
			<h2>{heading}</h2>
			<p>{subheading}</p>
		</div>
		{sliderRow ? (
			<div class="team-slider-wrap">
				<div class="team-slider">
					{members.map((member) => (
						<a href={`/team/${member.slug}`} class="team-card team-card-slide">
							{member.photo ? (
								<div class="team-photo-wrap team-photo-wrap--img">
									<img src={member.photo} alt={member.name} loading="lazy" />
								</div>
							) : (
								<div class="team-photo-wrap" style={`background: ${gradientFor(member.name)};`}>
									<span class="team-initials">{initials(member.name)}</span>
								</div>
							)}
							<div class="info">
								<h3>{member.name}</h3>
								<span class="role">{member.role}</span>
							</div>
						</a>
					))}
				</div>
				<div class="team-slider-nav">
					<button class="team-slider-btn" data-dir="-1" aria-label="Previous">&larr;</button>
					<button class="team-slider-btn" data-dir="1" aria-label="Next">&rarr;</button>
				</div>
			</div>
		) : (
			<div class="team-grid">
				{members.map((member) => (
					<a href={`/team/${member.slug}`} class="team-card">
						{member.photo ? (
							<div class="team-photo-wrap team-photo-wrap--img">
								<img src={member.photo} alt={member.name} loading="lazy" />
							</div>
						) : (
							<div class="team-photo-wrap" style={`background: ${gradientFor(member.name)};`}>
								<span class="team-initials">{initials(member.name)}</span>
							</div>
						)}
						<div class="info">
							<h3>{member.name}</h3>
							<span class="role">{member.role}</span>
						</div>
					</a>
				))}
			</div>
		)}
	</div>
</section>

<style>
	.bp-page .team-card { display: block; cursor: pointer; }
	.team-photo-wrap {
		width: 100%;
		height: 240px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}
	.team-photo-wrap--img { padding: 0; }
	.team-photo-wrap--img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}
	.team-initials {
		color: #ffffff;
		font-size: 54px;
		font-weight: 800;
		letter-spacing: -2px;
		font-family: 'Inter', sans-serif;
	}
	/* Grid mode (team page), 5 per row, compact cards */
	.bp-page .team:not(.team-slider-mode) .team-grid {
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 20px;
	}
	.bp-page .team:not(.team-slider-mode) .team-card .info { padding: 18px 16px 20px; }
	.bp-page .team:not(.team-slider-mode) .team-card h3 { font-size: 16px; }
	.bp-page .team:not(.team-slider-mode) .team-card .team-link-btn { top: 216px; width: 40px; height: 40px; font-size: 16px; right: 14px; }

	/* Centered mode (Wellness page) — small fixed-width cards, horizontally centred */
	/* Note: no `.bp-page` prefix because that ancestor is rendered outside this component
	   and doesn't pick up Astro's scoping attribute, which would prevent the rule matching. */
	.team.team-centered-mode .team-grid {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 24px;
		max-width: 900px;
		margin: 0 auto;
	}
	.team.team-centered-mode .team-card {
		flex: 0 0 240px;
	}
	.team.team-centered-mode .team-photo-wrap { height: 280px; }
	@media (max-width: 600px) {
		.team.team-centered-mode .team-card { flex: 0 0 100%; max-width: 280px; }
	}

	/* Horizontal slider for homepage */
	.team-slider-wrap { position: relative; }
	.team-slider {
		display: flex; gap: 20px;
		overflow-x: auto;
		padding-bottom: 24px;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
	}
	.team-slider::-webkit-scrollbar { height: 4px; }
	.team-slider::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); border-radius: 4px; }
	.team-slider::-webkit-scrollbar-thumb { background: #e87722; border-radius: 4px; }
	.team-card-slide {
		flex: 0 0 240px;
		scroll-snap-align: start;
	}
	.team-card-slide .team-photo-wrap { height: 240px; }
	.team-card-slide .team-initials { font-size: 54px; }
	.team-slider-nav { display: flex; justify-content: flex-end; gap: 12px; margin-top: 16px; }
	.team-slider-btn {
		width: 44px; height: 44px; border-radius: 50%;
		border: 2px solid rgba(0,0,0,0.15); background: transparent;
		color: #1a1a1a; font-size: 18px; cursor: pointer;
		display: flex; align-items: center; justify-content: center;
		transition: all .2s;
	}
	.team-slider-btn:hover { border-color: #e87722; background: #e87722; color: #fff; }
	@media (max-width: 768px) {
		.team-card-slide { flex: 0 0 180px; }
		.team-card-slide .team-photo-wrap { height: 200px; }
		.team-card-slide .team-initials { font-size: 44px; }
	}
</style>

<script is:inline>
	(function () {
		document.querySelectorAll('.team-slider-wrap').forEach(function (wrap) {
			var slider = wrap.querySelector('.team-slider');
			wrap.querySelectorAll('.team-slider-btn').forEach(function (btn) {
				btn.addEventListener('click', function () {
					var dir = parseInt(btn.getAttribute('data-dir'), 10) || 1;
					slider.scrollBy({ left: dir * 260, behavior: 'smooth' });
				});
			});
		});
	})();
</script>
