---
const conditions = [
	{ label: 'Back Pain', href: '/condition/lower-back-pain/' },
	{ label: 'Neck Pain', href: '/condition/neck-pain/' },
	{ label: 'Foot Pain', href: '/condition/foot-pain/' },
	{ label: 'Ankle Pain', href: '/condition/ankle-pain/' },
	{ label: 'Knee & ACL', href: '/condition/acl-knee-specialist-london/' },
	{ label: 'Hip Pain', href: '/condition/hip-pain/' },
	{ label: 'Shoulder Pain', href: '/condition/shoulder-specialist-physiotherapy/' },
	{ label: 'Elbow Pain', href: '/condition/elbow-pain/' },
	{ label: "Women's Pelvic Health", href: '/condition/womens-pelvic-health/' },
	{ label: "Men's Pelvic Health", href: '/condition/mens-pelvic-health/' },
	{ label: 'Running Injuries', href: '/condition/running-injuries/' },
	{ label: 'Cycling Injuries', href: '/condition/cycling-injuries/' },
	{ label: 'Sports Injuries', href: '/service/sports-physiotherapy/' },
	{ label: 'Multiple Sclerosis', href: '/condition/multiple-sclerosis/' },
	{ label: 'Stroke', href: '/condition/stroke/' },
	{ label: "Parkinson's", href: '/condition/parkinsons/' },
	{ label: 'Neurological Pathologies', href: '/service/specialist-neuro-physio-london/' },
	{ label: 'Verrucas', href: '/condition/verrucas/' },
	{ label: 'Ingrown Toenails', href: '/condition/ingrown-toenails/' },
	{ label: 'Dizziness', href: '/condition/balance-and-dizziness/' },
	{ label: 'TMJ & Jaw Pain', href: '/service/tmj-and-jaw-pain/' },
];
---

<section class="clinics">
	<div class="container">
		<div class="clinics-header">
			<div class="clinics-header-left">
				<div class="hero-badge"><span class="dot"></span> What We Treat</div>
				<h2>Conditions We Treat</h2>
			</div>
			<div class="clinics-header-right">
				<p>Our Chartered Physiotherapists treat a variety of conditions and injuries including, but not limited to, the following. If your condition is not listed please <a href="/contact-us/">get in touch</a>.</p>
			</div>
		</div>
		<div class="clinic-tags">
			{conditions.map((c, i) => (
				<a href={c.href} class={`clinic-tag${i % 2 === 1 ? ' alt' : ''}`}>{c.label}</a>
			))}
		</div>
	</div>
</section>
