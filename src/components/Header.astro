---
const serviceColumns = [
	[
		{
			label: 'MSK & Sports',
			items: [
				{ label: 'Physiotherapy', href: '/service/physiotherapy' },
				{ label: 'Sports Physiotherapy', href: '/service/sports-physiotherapy' },
				{ label: 'Osteopathy and Nutrition', href: '/service/osteopathy' },
				{ label: 'Sports Massage', href: '/service/sports-massage' },
				{ label: 'Shockwave Therapy', href: '/service/shockwave-therapy' },
				{ label: 'Prehab Class', href: '/service/prehab-class' },
			],
		},
		{
			label: 'Neurological',
			items: [
				{ label: 'Neurological Rehabilitation', href: '/service/neurological-rehabilitation' },
				{ label: 'Vojta Therapy', href: '/service/vojta-therapy' },
			],
		},
	],
	[
		{
			label: 'Pelvic Health',
			items: [
				{ label: "Women's Health", href: '/service/womens-health' },
				{ label: "Men's Health", href: '/service/mens-health' },
			],
		},
		{
			label: 'Foot & Lower Limb',
			items: [
				{ label: 'Podiatry', href: '/service/podiatry' },
				{ label: 'Hydrotherapy', href: '/service/hydrotherapy' },
			],
		},
	],
	[
		{
			label: 'Performance & Strength',
			sublabel: '(Fitness & Performance)',
			items: [
				{ label: 'Strength & Conditioning', href: '/service/strength-conditioning' },
				{ label: 'Lift (Weight Training) Club', href: '/service/lift-weight-training-club' },
				{ label: 'Bike Fitting & Running Analysis', href: '/service/bike-fitting-running-analysis' },
			],
		},
		{
			label: 'Paediatric',
			items: [
				{ label: 'Youth Physiotherapy', href: '/service/paediatric-sports-physiotherapy' },
				{ label: 'Vojta Therapy', href: '/service/vojta-therapy' },
			],
		},
	],
	[
		{
			label: 'Recovery & Wellness',
			items: [
				{ label: 'Wellness', href: '/service/psychological-wellness' },
				{ label: 'Anti-Gravity Treadmill', href: '/service/anti-gravity-treadmill' },
				{ label: 'Ergonomics', href: '/service/ergonomics' },
				{ label: 'TMJ & Jaw Pain', href: '/service/tmj-and-jaw-pain' },
			],
		},
		{
			label: 'Clinical Support / Advanced Care',
			items: [
				{ label: 'Physiotherapy Prescribing', href: '/service/physiotherapy-prescribing' },
				{ label: 'Outcome Measures', href: '/service/outcome-measures' },
			],
		},
	],
];
// Flat list for mobile fallback
const services = serviceColumns.flat().flatMap((g) => g.items);

const conditions = [
	{ label: 'Lower Back Pain', href: '/condition/lower-back-pain' },
	{ label: 'Neck Pain', href: '/condition/neck-pain' },
	{ label: 'Shoulder Pain', href: '/condition/shoulder-pain' },
	{ label: 'Elbow Pain', href: '/condition/elbow-pain' },
	{ label: 'Hip Pain', href: '/condition/hip-pain' },
	{ label: 'Knee Injuries', href: '/condition/knee-injuries' },
	{ label: 'Foot Pain', href: '/condition/foot-pain' },
	{ label: 'Ankle Pain', href: '/condition/ankle-pain' },
	{ label: 'Cycling Injuries', href: '/condition/cycling-injuries' },
	{ label: 'Running Injuries', href: '/condition/running-injuries' },
	{ label: "Women's Pelvic Health", href: '/condition/womens-pelvic-health' },
	{ label: "Men's Pelvic Health", href: '/condition/mens-pelvic-health' },
	{ label: 'Verrucas', href: '/condition/verrucas' },
	{ label: 'Ingrown Toenails', href: '/condition/ingrown-toenails' },
	{ label: 'Multiple Sclerosis', href: '/condition/multiple-sclerosis' },
	{ label: 'Stroke', href: '/condition/stroke' },
	{ label: "Parkinson's", href: '/condition/parkinsons' },
	{ label: 'Balance & Dizziness', href: '/condition/balance-and-dizziness' },
	{ label: "Children's Neurological & Developmental", href: '/condition/childrens-neurological-developmental' },
];

const about = [
	{ label: 'About Us', href: '/about-us' },
	{ label: 'Meet The Team', href: '/meet-the-team' },
	{ label: 'Our Clinic', href: '/our-clinic' },
	{ label: 'Our Studios', href: '/our-studios' },
	{ label: 'Outcomes', href: '/outcomes' },
	{ label: 'Pricing', href: '/pricing' },
	{ label: 'Work For Us', href: '/work-for-us' },
	{ label: 'Testimonials', href: '/testimonials' },
];

const whoWeHelp = [
	{ label: 'The Performance Athlete', href: '/who-we-help/the-performance-athlete' },
	{ label: 'The Club Athlete', href: '/who-we-help/the-club-athlete' },
	{ label: 'Are you planning an event?', href: '/who-we-help/are-you-planning-an-event' },
	{ label: 'Marathon Runners & Endurance Athletes', href: '/who-we-help/marathon-endurance' },
	{ label: 'Active People', href: '/who-we-help/active-people' },
	{ label: 'Pre & Post-natal Women', href: '/who-we-help/pre-post-natal' },
	{ label: 'People with Neurological Conditions', href: '/who-we-help/neurological-conditions' },
	{ label: 'Children & Young People', href: '/who-we-help/children-young-people' },
	{ label: 'Post-Surgical Patients', href: '/who-we-help/post-surgical' },
];

const locations = [
	{ label: 'Main Clinic: Clapham North', href: '/clinic/clapham' },
	{ label: 'Clapham South for Hydrotherapy', href: '/clinic/clapham-south-hydrotherapy' },
];
---
<header class="bp-header">
	<div class="header-inner">
		<a href="/" class="logo" aria-label="Balance Performance Physiotherapy home">
			<img src="/logo.jpg" alt="Balance Performance Physiotherapy" />
		</a>
		<nav>
			<ul>
				<li class="has-dropdown">
					<a href="/about-us">About <span class="chev">▾</span></a>
					<div class="dropdown">
						{about.map((item) => <a href={item.href}>{item.label}</a>)}
					</div>
				</li>
				<li class="has-dropdown has-dropdown-services-mega">
					<a href="/services">Services <span class="chev">▾</span></a>
					<div class="dropdown dropdown-services-mega">
						<div class="services-mega-inner">
							{serviceColumns.map((col) => (
								<div class="services-col">
									{col.map((group) => (
										<div class="services-group">
											<div class="services-group-label">
												{group.label}
												{group.sublabel && <><br/><span class="services-group-sublabel">{group.sublabel}</span></>}
											</div>
											{group.items.map((item) => (
												<a href={item.href}>{item.label}</a>
											))}
										</div>
									))}
								</div>
							))}
						</div>
					</div>
				</li>
				<li class="has-dropdown has-dropdown-wide">
					<a href="/conditions">Conditions <span class="chev">▾</span></a>
					<div class="dropdown dropdown-wide">
						{conditions.map((item) => <a href={item.href}>{item.label}</a>)}
					</div>
				</li>
				<li class="has-dropdown has-dropdown-mega">
					<a href="/who-we-help">Who We Help <span class="chev">▾</span></a>
					<div class="dropdown dropdown-mega">
						<div class="mega-left">
							<div class="mega-eyebrow">Who We Help</div>
							<p class="mega-intro">Whether it's aches and pains, sports injuries, pre- and post-natal care, neurological conditions, or post-surgical rehab, we've got the skills and experience to support you.</p>
							<div class="mega-links">
								{whoWeHelp.map((item) => <a href={item.href}>{item.label}</a>)}
							</div>
						</div>
						<a href="https://go.mindbodyonline.com/book/widgets/appointments/view/8068777f5e/services" target="_blank" rel="noopener" class="mega-card" style="background-image: url('/sports-physio/hero-running.jpg')">
							<span class="mega-card-button">Book Now</span>
						</a>
					</div>
				</li>
				<li><a href="/faqs">FAQs</a></li>
				<li class="has-dropdown has-dropdown-mega">
					<a href="/clinic/clapham">Our Locations <span class="chev">▾</span></a>
					<div class="dropdown dropdown-mega">
						<div class="mega-left">
							<div class="mega-eyebrow">Our Locations</div>
							<p class="mega-intro">Our main clinic is on Gauden Road in Clapham. Our hydrotherapy service is based in Audley Village.</p>
							<div class="mega-links">
								{locations.map((item) => <a href={item.href}>{item.label}</a>)}
							</div>
						</div>
						<a href="/clinic/clapham" class="mega-card" style="background-image: url('/clapham/opening-hours-banners.jpg')" aria-label="Visit our Clapham clinic page"></a>
					</div>
				</li>
				<li><a href="/contact-us">Contact Us</a></li>
			</ul>
		</nav>
		<div class="header-cta">
			<a href="https://go.mindbodyonline.com/book/widgets/appointments/view/8068777f5e/services" target="_blank" rel="noopener" class="btn-primary">Book Now</a>
			<button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</div>
</header>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
	<div class="mobile-menu-inner">
		<ul class="mobile-nav">
			<li>
				<details>
					<summary>About</summary>
					<ul class="mobile-sublist">
						{about.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
					</ul>
				</details>
			</li>
			<li>
				<details>
					<summary>Services</summary>
					<ul class="mobile-sublist">
						<li><a href="/services">All services</a></li>
						{serviceColumns.flat().map((group) => (
							<>
								<li class="mobile-sublist-category">{group.label}{group.sublabel && <> {group.sublabel}</>}</li>
								{group.items.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
							</>
						))}
					</ul>
				</details>
			</li>
			<li>
				<details>
					<summary>Conditions</summary>
					<ul class="mobile-sublist">
						<li><a href="/conditions">All conditions</a></li>
						{conditions.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
					</ul>
				</details>
			</li>
			<li>
				<details>
					<summary>Who We Help</summary>
					<ul class="mobile-sublist">
						<li><a href="/who-we-help">Overview</a></li>
						{whoWeHelp.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
					</ul>
				</details>
			</li>
			<li><a href="/faqs" class="mobile-direct">FAQs</a></li>
			<li>
				<details>
					<summary>Our Locations</summary>
					<ul class="mobile-sublist">
						{locations.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
					</ul>
				</details>
			</li>
			<li><a href="/contact-us" class="mobile-direct">Contact Us</a></li>
		</ul>
		<a href="https://go.mindbodyonline.com/book/widgets/appointments/view/8068777f5e/services" target="_blank" rel="noopener" class="mobile-menu-book">Book Now</a>
	</div>
</div>

<style>
	.bp-header {
		position: fixed; top: 0; left: 0; right: 0; z-index: 100;
		background: transparent;
		border-bottom: 1px solid rgba(255,255,255,0.15);
		transition: background .3s ease, border-color .3s ease, box-shadow .3s ease;
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}
	.bp-header.is-scrolled {
		background: rgba(44, 67, 86, 0.96);
		border-bottom: 1px solid rgba(255,255,255,0.08);
		box-shadow: 0 4px 20px rgba(0,0,0,0.15);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}
	.header-inner {
		display: flex; align-items: center; justify-content: space-between;
		padding: 16px 24px; max-width: 1200px; margin: 0 auto;
	}
	.logo {
		display: inline-flex; align-items: center;
		text-decoration: none;
	}
	.logo img {
		height: 52px; width: auto; display: block;
	}
	nav ul { display: flex; gap: 32px; list-style: none; margin: 0; padding: 0; align-items: center; }
	nav > ul > li { position: relative; }
	nav a { font-weight: 500; font-size: 15px; color: rgba(255,255,255,0.85); transition: color .2s; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
	nav a:hover { color: #ffffff; }
	.chev { font-size: 10px; opacity: 0.7; }

	.has-dropdown .dropdown {
		position: absolute; top: 100%; left: 0;
		background: #ffffff;
		border-radius: 12px;
		box-shadow: 0 12px 40px rgba(0,0,0,0.18);
		min-width: 220px;
		padding: 12px;
		opacity: 0; visibility: hidden;
		transform: translateY(8px);
		transition: opacity .2s, transform .2s, visibility .2s;
		z-index: 200;
		display: flex; flex-direction: column; gap: 2px;
	}
	.has-dropdown .dropdown.dropdown-wide {
		display: grid;
		grid-template-columns: repeat(3, minmax(180px, 1fr));
		min-width: 600px;
		padding: 16px;
		gap: 4px 20px;
	}

	/* Services mega menu (4 columns, categorised) */
	.has-dropdown-services-mega .dropdown.dropdown-services-mega {
		min-width: 920px;
		padding: 0;
		left: 50%;
		transform: translateX(-50%) translateY(8px);
	}
	.has-dropdown-services-mega:hover .dropdown.dropdown-services-mega,
	.has-dropdown-services-mega:focus-within .dropdown.dropdown-services-mega {
		transform: translateX(-50%) translateY(0);
	}
	.services-mega-inner {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 28px 36px;
		padding: 32px 36px 36px;
	}
	.services-col { display: flex; flex-direction: column; gap: 28px; }
	.services-group { display: flex; flex-direction: column; gap: 2px; }
	.services-group-label {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #e87722;
		line-height: 1.35;
		margin-bottom: 10px;
	}
	.services-group-sublabel {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #e87722;
	}
	.services-group a {
		display: block;
		padding: 6px 10px;
		margin-left: -10px;
		border-radius: 6px;
		font-size: 14px;
		font-weight: 500;
		color: #1a1a1a;
		text-decoration: none;
		line-height: 1.4;
		transition: background .15s, color .15s;
	}
	.services-group a:hover {
		background: #f4f6f7;
		color: #e87722;
	}

	/* Mobile category heading within Services */
	.mobile-sublist .mobile-sublist-category {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #e87722;
		padding: 16px 0 6px;
		list-style: none;
	}

	/* Mega menu (Who We Help) */
	.has-dropdown-mega .dropdown.dropdown-mega {
		display: grid;
		grid-template-columns: minmax(320px, 1fr) 280px;
		min-width: 640px;
		left: auto;
		right: 0;
		padding: 0;
		gap: 0;
		overflow: hidden;
	}
	.dropdown-mega .mega-left {
		padding: 28px 28px 24px;
		display: flex;
		flex-direction: column;
	}
	.dropdown-mega .mega-eyebrow {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #e87722;
		margin-bottom: 12px;
	}
	.dropdown-mega .mega-intro {
		font-size: 14px;
		line-height: 1.5;
		color: #4b5563;
		margin: 0 0 18px;
	}
	.dropdown-mega .mega-links {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.dropdown-mega .mega-links a {
		padding: 10px 12px;
		border-radius: 8px;
		font-size: 14px;
		font-weight: 600;
		color: #1a1a1a;
		transition: background .15s, color .15s;
	}
	.dropdown-mega .mega-links a:hover {
		background: #3EBEDF;
		color: #ffffff;
	}
	.dropdown-mega .mega-card {
		position: relative;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		min-height: 260px;
		text-decoration: none;
		overflow: hidden;
		padding: 20px;
		border-radius: 0;
		font-size: inherit;
		font-weight: inherit;
		transform: none;
		transition: none;
	}
	.dropdown-mega .mega-card::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0) 70%);
		pointer-events: none;
	}
	.dropdown-mega .mega-card:hover,
	.dropdown-mega .mega-card:focus,
	.dropdown-mega .mega-card:active {
		background-color: transparent;
		background-size: cover;
		background-position: center;
		transform: none;
	}
	.dropdown-mega .mega-card-button {
		position: relative;
		z-index: 1;
		display: inline-block;
		padding: 12px 28px;
		background: #3EBEDF;
		color: #ffffff;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.03em;
		border-radius: 50px;
		transition: background .2s ease, transform .15s ease;
	}
	.dropdown-mega .mega-card:hover .mega-card-button {
		background: #32a8c6;
		transform: translateY(-2px);
	}
	.dropdown-mega .mega-card-overlay {
		width: 100%;
		padding: 20px;
		background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.25) 60%, rgba(0,0,0,0) 100%);
		color: #ffffff;
	}
	.dropdown-mega .mega-card-title {
		font-size: 22px;
		font-weight: 700;
		line-height: 1.2;
		margin-bottom: 8px;
		color: #ffffff;
	}
	.dropdown-mega .mega-card-cta {
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #ffffff;
		opacity: 0.95;
	}
	.dropdown-mega .mega-card:hover .mega-card-cta {
		opacity: 1;
	}

	.has-dropdown .dropdown a {
		color: #1a1a1a;
		padding: 8px 12px;
		border-radius: 8px;
		font-size: 14px;
		font-weight: 500;
		transition: background-color .15s, color .15s;
	}
	.has-dropdown .dropdown a:hover {
		background-color: #f4f6f7;
		color: #e87722;
	}
	.has-dropdown:hover .dropdown,
	.has-dropdown:focus-within .dropdown {
		opacity: 1; visibility: visible; transform: translateY(0);
	}

	.header-cta { display: flex; gap: 12px; align-items: center; }
	.header-cta .btn-primary {
		padding: 10px 24px; border-radius: 50px; font-weight: 600; font-size: 14px;
		color: #ffffff; background: #3EBEDF; border: none;
		cursor: pointer; transition: all .2s; text-decoration: none;
		display: inline-block;
	}
	.header-cta .btn-primary:hover { background: #32a8c6; }

	/* Hamburger button, hidden on desktop */
	.hamburger {
		display: none;
		background: transparent;
		border: 0;
		padding: 8px;
		cursor: pointer;
		width: 40px; height: 40px;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
	}
	.hamburger span {
		display: block;
		width: 22px; height: 2px;
		background: #ffffff;
		border-radius: 2px;
		transition: transform .25s, opacity .2s;
	}
	.hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
	.hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
	.hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

	@media (max-width: 900px) {
		nav ul { display: none; }
		.hamburger { display: inline-flex; }
		.header-cta .btn-primary { display: none; }
	}
</style>

<style is:global>
	/* Mobile full-screen menu panel (outside Header scope, so global) */
	.mobile-menu {
		position: fixed; top: 0; left: 0; right: 0; bottom: 0;
		background: #2c4356;
		z-index: 99;
		padding-top: 90px;
		overflow-y: auto;
		opacity: 0; visibility: hidden;
		transition: opacity .25s ease, visibility .25s ease;
		font-family: 'Inter', sans-serif;
	}
	.mobile-menu.is-open { opacity: 1; visibility: visible; }
	.mobile-menu-inner { padding: 16px 24px 48px; max-width: 640px; margin: 0 auto; }
	.mobile-nav { list-style: none; margin: 0; padding: 0; }
	.mobile-nav > li {
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}
	.mobile-nav details > summary {
		list-style: none;
		padding: 16px 0;
		font-size: 18px;
		font-weight: 600;
		color: #ffffff;
		cursor: pointer;
		display: flex; justify-content: space-between; align-items: center;
	}
	.mobile-nav details > summary::-webkit-details-marker { display: none; }
	.mobile-nav details > summary::after {
		content: '+';
		font-size: 26px; font-weight: 400;
		color: #e87722;
		transition: transform .2s;
	}
	.mobile-nav details[open] > summary::after { transform: rotate(45deg); }
	.mobile-sublist {
		list-style: none; margin: 0; padding: 0 0 16px 12px;
	}
	.mobile-sublist li { padding: 0; }
	.mobile-sublist a {
		display: block;
		padding: 10px 0;
		font-size: 15px;
		color: rgba(255,255,255,0.8);
		text-decoration: none;
	}
	.mobile-sublist a:hover, .mobile-sublist a:active { color: #e87722; }
	.mobile-direct {
		display: block;
		padding: 16px 0;
		font-size: 18px; font-weight: 600;
		color: #ffffff;
		text-decoration: none;
	}
	.mobile-menu-book {
		display: block;
		margin-top: 28px;
		padding: 16px 24px;
		background: #e87722;
		color: #ffffff;
		text-align: center;
		font-size: 16px; font-weight: 700;
		border-radius: 50px;
