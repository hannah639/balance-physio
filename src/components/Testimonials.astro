---
// Testimonials section — renders a Trustindex Google Reviews widget
// in place of the old static testimonial cards.
// Used on the homepage and the About Us page.
---

<section class="testimonials">
	<div class="container">
		<div class="section-header">
			<h2>Kind words from our happy clients</h2>
		</div>
		<div class="testimonials-trustindex">
			<script defer async src="https://cdn.trustindex.io/loader.js?65abd11700e3871410561ef024c"></script>
		</div>
	</div>
</section>

<style>
	.testimonials-trustindex {
		max-width: 1100px;
		margin: 0 auto;
		min-height: 100px; /* reserve space while widget loads */
	}
</style>
