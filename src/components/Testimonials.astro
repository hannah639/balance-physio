---
import { sanityClient, urlFor } from '../lib/sanity.js';

const testimonials = await sanityClient.fetch(
  `*[_type == "testimonial"] | order(order asc) {
    _id,
    quote,
    name,
    description,
    avatar
  }`
);
---

<section class="testimonials">
	<div class="container">
		<div class="section-header">
			<h2>Kind words from our happy clients</h2>
		</div>
		<div class="testimonial-grid">
			{testimonials.map((t) => (
				<div class="testimonial-card">
					<p>{t.quote}</p>
					<div class="testimonial-author">
						{t.avatar && (
							<div class="testimonial-avatar">
								<img src={urlFor(t.avatar).width(120).height(120).url()} alt={t.name} />
							</div>
						)}
						<div>
							<h4>{t.name}</h4>
							<span>{t.description}</span>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
