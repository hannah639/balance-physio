---
<Layout
	title="Pricing"
	description="Transparent pricing for physiotherapy, osteopathy, sports massage, strength & conditioning, podiatry and more at Balance Performance Physiotherapy in Clapham."
>
	<PageHero
		title="&amp; Insurance"
		highlight="Pricing"
		subtitle="Transparent fees that reflect our clinical expertise. Recognised by all major insurance providers including Bupa and AXA PPP."
		breadcrumb="Pricing"
	/>

	<section class="pricing-section">
		<div class="container">
			<div class="price-card-grid">
				{pricingCategories.map((cat) => (
					<div class="price-card" id={cat.anchor}>
						<h2 class="price-card-title">{cat.title}</h2>
						<ul class="price-card-list">
							{cat.items.map((item) => (
								<li class="price-card-row">
									<div class="price-card-row-main">
										<span class="price-card-name">{item.name}</span>
										{item.note && <span class="price-card-note">{item.note}</span>}
									</div>
									<span class="price-card-price">{item.price}</span>
								</li>
							))}
						</ul>
						<a class="price-card-cta" href={BOOKING_URL} target="_blank" rel="noopener">Book Now</a>
					</div>
				))}
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>

<style>
	.price-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 24px;
	}
	.price-card {
		background: #ffffff;
		border: 1px solid #e5e9ec;
		border-radius: 15px;
		padding: 32px 28px;
		display: flex;
		flex-direction: column;
		box-shadow: 0 1px 2px rgba(0,0,0,0.03);
		transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
		/* Offset for the fixed header so anchor scrolls don't hide the card title underneath it. */
		scroll-margin-top: 150px;
	}
	.price-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 14px 40px rgba(0,0,0,0.08);
		border-color: #e87722;
	}
	.price-card-title {
		font-size: 22px;
		font-weight: 800;
		letter-spacing: -0.5px;
		line-height: 1.25;
		margin: 0 0 20px;
		color: #1a1a1a;
	}
	.price-card-list {
		list-style: none;
		margin: 0 0 24px;
		padding: 0;
		flex: 1;
	}
	.price-card-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
		padding: 14px 0;
		border-bottom: 1px solid #eef1f3;
	}
	.price-card-row:last-child { border-bottom: 0; }
	.price-card-row-main {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
	}
	.price-card-name {
		font-size: 15px;
		font-weight: 600;
		color: #1a1a1a;
		line-height: 1.35;
	}
	.price-card-note {
		font-size: 12px;
		color: #6b7680;
		letter-spacing: 0.2px;
	}
	.price-card-price {
		font-size: 18px;
		font-weight: 800;
		color: #e87722;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.price-card-cta {
		display: inline-block;
		margin-top: auto;
		text-align: center;
		padding: 14px 24px;
		border-radius: 50px;
		background: #3EBEDF;
		color: #ffffff;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		transition: background .2s ease, transform .2s ease;
	}
	.price-card-cta:hover {
		background: #32a8c6;
		transform: translateY(-1px);
	}
	@media (max-width: 768px) {
		.price-card-grid {
			grid-template-columns: 1fr;
			gap: 20px;
		}
		.price-card { padding: 28px 22px; }
		.price-card-title { font-size: 20px; }
	}
</style>
