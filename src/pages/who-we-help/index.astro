---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import BookingCTA from '../../components/BookingCTA.astro';

const groups = [
	{ title: 'The Performance Athlete', href: '/who-we-help/the-performance-athlete' },
	{ title: 'The Club Athlete', href: '/who-we-help/the-club-athlete' },
	{ title: 'Are you planning an event?', href: '/who-we-help/are-you-planning-an-event' },
	{ title: 'Marathon Runners & Endurance Athletes', href: '/who-we-help/marathon-endurance' },
	{ title: 'Active People', href: '/who-we-help/active-people' },
	{ title: 'Pre & Post-natal Women', href: '/who-we-help/pre-post-natal' },
	{ title: 'People with Neurological Conditions', href: '/who-we-help/neurological-conditions' },
	{ title: 'Children & Young People', href: '/who-we-help/children-young-people' },
	{ title: 'Post-Surgical Patients', href: '/who-we-help/post-surgical' },
];
---
<Layout
	title="Who We Help"
	description="Whether it's aches and pains, sports injuries, pre- and post-natal care, neurological conditions or post-surgical rehab, we've got the skills and experience to support you."
>
	<PageHero
		title="Who We Help"
		breadcrumb="Who We Help"
	/>

	<section class="link-grid-section">
		<div class="container">
			<div class="link-grid">
				{groups.map((g) => (
					<a href={g.href} class="link-grid-item">
						<h3>{g.title}</h3>
						<span class="arrow">Learn more &rsaquo;</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>
