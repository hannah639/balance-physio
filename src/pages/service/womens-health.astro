---
import ServicePage from '../../components/ServicePage.astro';

const sliderImages = [
	{ src: '/womens-health/slider-physiotherapy.webp', alt: 'Women\'s health physiotherapy at Balance Physio Clapham' },
	{ src: '/womens-health/slider-clinic-2017.jpg', alt: 'Clapham clinic treatment session' },
	{ src: '/womens-health/slider-img8036.webp', alt: 'Women\'s health assessment at Balance Physio Clapham' },
	{ src: '/womens-health/slider-img7976.webp', alt: 'Pelvic health physiotherapy session' },
	{ src: '/womens-health/slider-mg1993.webp', alt: 'Treatment room at Balance Physio Clapham' },
	{ src: '/womens-health/slider-mg2336.webp', alt: 'Women\'s health treatment at Balance Physio Clapham' },
];
---
<ServicePage
	title="in Clapham"
	highlight="Women\'s Health"
	heroSubtitle="Expert pelvic health physiotherapy supporting you through pregnancy, postnatal recovery, menopause, and every stage in between."
	breadcrumb="Women\'s Health"
	seoTitle="Women\'s Health in Clapham"
	seoDescription="Women\'s health physiotherapy in Clapham. Pelvic floor, pregnancy, postnatal recovery, Mummy MOT, and menopause support from experienced clinicians."
	marqueeImages={sliderImages}
	intro={[
		"Women\'s health physiotherapy addresses the physical changes that occur across different stages of life — from adolescence through pregnancy, postnatal recovery, and menopause.",
		"We take a clinical and structured approach to pelvic health, assessing how symptoms affect movement, strength, and daily function.",
		"From this we build a clear plan to help you regain control, confidence, and resilience.",
	]}
	introImage="/womens-health/gynaecology.webp"
	whenHeading="When to consider"
	whenHighlight="an assessment"
	whenIntro="You may benefit from assessment if experiencing:"
	whenList={[
		"Pelvic girdle pain, lower back pain, or discomfort during pregnancy",
		"Bladder or bowel issues, including leaking or urgency",
		"Postnatal changes such as abdominal separation or pelvic floor weakness",
		"Symptoms of pelvic organ prolapse (heaviness or pressure)",
		"Pain during intimacy or scar-related discomfort",
		"Ongoing symptoms following gynaecological surgery",
	]}
	whenImage="/womens-health/pregnant-woman.jpg"
	howHeading="How we"
	howHighlight="treat"
	howIntro="Treatment may include:"
	howList={[
		"Pelvic floor assessment and rehabilitation",
		"Hands-on therapy to improve joint and soft tissue function",
		"Targeted strength and control exercises",
		"Postural and movement retraining",
		"Education around lifestyle, load management, and recovery",
	]}
	howImage="/womens-health/sports-woman.jpg"
	whoHeading="Who we"
	whoHighlight="help"
	whoIntro="We support women across all life stages:"
	whoList={[
		"Pregnancy: managing pain and staying active",
		"Postnatal recovery: from 6 weeks onwards, including Mummy MOT",
		"Active women: managing symptoms during sport and exercise",
		"Perimenopause and menopause: addressing pelvic floor changes",
		"Post-surgical recovery: following gynaecological procedures",
	]}
	whoImage="/womens-health/women-huddle.jpg"
	faqs={[
		{ q: "What is a Mummy MOT?", a: "A specialist postnatal assessment from 6 weeks onwards, including pelvic floor, abdominal, and postural checks." },
		{ q: "Do I need to be pregnant to see you?", a: "No. We treat women of all ages for pelvic health concerns." },
		{ q: "Is an internal examination required?", a: "No. It is optional, and clinicians discuss this beforehand." },
		{ q: "Can physiotherapy help with pain during sex?", a: "Yes. Many causes relate to muscle function or scar tissue, which can be treated." },
		{ q: "When should I seek help for pelvic girdle pain?", a: "As soon as symptoms begin — early treatment reduces discomfort." },
		{ q: "Can I bring my baby?", a: "Yes — patients are welcome to bring babies to appointments." },
	]}
/>
