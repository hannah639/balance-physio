---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
	title="in Clapham"
	highlight="Psychological Wellness"
	heroSubtitle="An integrated approach recognising that pain, injury, stress, and performance are all influenced by the nervous system and your psychological state."
	breadcrumb="Psychological Wellness"
	seoTitle="Psychological Wellness in Clapham"
	seoDescription="Psychological wellness support in Clapham. Integrated care for pain, injury, stress and performance, supporting recovery and long-term resilience."
	intro={[
		"Psychological wellness is a core component of recovery, performance, and long-term health.",
		"At Balance, we take an integrated approach — recognising that pain, injury, stress, and physical performance are all influenced by the nervous system and your psychological state.",
	]}
	whenHeading="When to consider"
	whenHighlight="this service"
	whenIntro="You may benefit from psychological wellness input if you:"
	whenList={[
		"Feel frustrated or low during injury or recovery",
		"Experience anxiety around movement or return to sport",
		"Struggle with persistent pain and fatigue",
		"Notice stress presenting as physical tension or symptoms",
		"Avoid activity due to fear of re-injury",
		"Feel a loss of motivation with rehabilitation or training",
	]}
	howHeading="How we"
	howHighlight="work"
	howIntro="Sessions may include:"
	howList={[
		"Understanding the relationship between pain, stress, and the nervous system",
		"Exploring your thoughts and feelings to your situation",
		"Strategies to manage stress and regulate your physiological response",
		"Breathing techniques and self awareness",
		"Building confidence in movement and activity",
		"Supporting return to training, sport, or daily function",
	]}
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Injury and rehabilitation patients",
		"People with persistent pain",
		"Athletes and active individuals",
		"Professionals",
		"Local population seeking improved resilience",
	]}
	faqs={[
		{ q: "Is this the same as traditional therapy?", a: "No. This service focuses on the interaction between psychological factors and physical health, particularly in relation to pain, injury, and performance." },
		{ q: "Do I need an injury to attend?", a: "No. Sessions suit anyone seeking stress management and performance support." },
		{ q: "Can this help with chronic pain?", a: "Yes. Psychological strategies can influence how pain is experienced and managed." },
		{ q: "How many sessions will I need?", a: "This varies. Some benefit from short-term input, others from ongoing support." },
		{ q: "Is breathwork included?", a: "Where appropriate, breathing techniques may be used for nervous system management." },
	]}
/>
