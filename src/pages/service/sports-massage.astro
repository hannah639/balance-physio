---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import ImageText from '../../components/ImageText.astro';
import PhotoMarquee from '../../components/PhotoMarquee.astro';
import BookingCTA from '../../components/BookingCTA.astro';

const photos = [
	{ src: '/sports-massage/01.jpg', alt: 'Sports massage session' },
	{ src: '/sports-massage/02.jpg', alt: 'Deep tissue treatment' },
	{ src: '/sports-massage/03.jpg', alt: 'Soft tissue therapy' },
	{ src: '/sports-massage/04.jpg', alt: 'Myofascial work' },
	{ src: '/sports-massage/05.jpg', alt: 'Trigger point therapy' },
	{ src: '/sports-massage/06.jpg', alt: 'Assisted stretching' },
	{ src: '/sports-massage/slider-extra-1.jpg', alt: 'Sports massage at Balance' },
	{ src: '/sports-massage/slider-extra-2.jpg', alt: 'Soft tissue release' },
];

const bookingUrl = 'https://go.mindbodyonline.com/book/widgets/appointments/view/8068777f5e/services';

const faqs = [
	{ q: 'Is sports massage only for athletes?', a: 'No. It is suitable for anyone with muscle tension, stiffness, or recovery needs, though it is particularly beneficial for those training regularly.' },
	{ q: 'Will it be painful?', a: 'Some techniques can be uncomfortable, but treatment should always remain manageable and controlled.' },
	{ q: 'How often should I have a massage?', a: 'This depends on your activity levels, but people who train frequently often benefit from regular sessions to support recovery and manage load.' },
	{ q: 'Can massage help with tight hips or back pain?', a: 'Yes. We often combine treatment with simple self-management strategies to maintain improvements.' },
	{ q: 'Can I do anything between sessions?', a: 'Yes. We will guide you on using tools such as massage balls and simple exercises to manage symptoms independently.' },
];
---
<Layout
	title="Sports Massage in Clapham"
	description="Sports massage and soft tissue therapy in Clapham: deep tissue, myofascial release, trigger point therapy and self-management guidance to support training and recovery."
>
	<PageHero title="in Clapham" highlight="Sports Massage" breadcrumb="Sports Massage" />

	<PhotoMarquee images={photos} heightPx={140} speedSeconds={45} />

	<ImageText eyebrow="Our approach" heading="Structured, targeted" highlight="soft tissue therapy" image="/sports-massage/02.jpg" imageAlt="Deep tissue treatment">
		<p>Sports massage and soft tissue therapy focus on improving muscle function, reducing tension, and supporting recovery from training, work, and daily life.</p>
		<p>At Balance, we take a structured approach to massage. Rather than purely passive treatment, sessions are used to address specific restrictions in muscle and fascia, particularly those that develop through regular or high training loads, while helping you understand how to manage your own symptoms between appointments.</p>
		<p>This allows massage to become part of a wider strategy for maintaining movement quality, supporting performance, and managing the ongoing demands of consistent training.</p>
		<p><a href={bookingUrl} target="_blank" rel="noopener" class="btn-primary">Book Now</a></p>
	</ImageText>

	<ImageText reverse altBg eyebrow="Symptoms" heading="When to consider" highlight="sports massage" image="/sports-massage/male-athlete-recovery.jpg" imageAlt="Male athlete catching his breath after training" imagePosition="70% center">
		<p>Sports massage isn't just for when something feels wrong; it's a key part of managing training load, improving recovery, and maintaining performance.</p>
		<p>You may benefit if you're experiencing:</p>
		<ul>
			<li>Muscle soreness or fatigue after training</li>
			<li>Persistent tightness affecting movement or performance</li>
			<li>Accumulated tension from high training volume or intensity</li>
			<li>Reduced flexibility or joint range of motion</li>
			<li>Ongoing tightness following injury or surgery</li>
			<li>Neck, shoulder, or back tension related to work or posture</li>
			<li>General physical stress and tension build-up</li>
		</ul>
		<p>Sports massage can be used both reactively and proactively, helping you recover between sessions, reduce injury risk, and keep your body performing at its best.</p>
	</ImageText>

	<ImageText eyebrow="Treatment" heading="How we" highlight="work" image="/sports-massage/03.jpg" imageAlt="Massage technique">
		<p>We focus on identifying areas of restriction and applying the appropriate techniques to improve tissue quality and movement, particularly in the context of your training demands.</p>
		<p>Your treatment may include:</p>
		<ul>
			<li>Deep tissue massage</li>
			<li>Myofascial release and fascial work</li>
			<li>Trigger point therapy</li>
			<li>Soft tissue release techniques (STR)</li>
			<li>Assisted stretching</li>
		</ul>
		<p>We also guide you on:</p>
		<ul>
			<li><strong>Self-massage techniques</strong> (e.g. using a ball, roller or massage tools)</li>
			<li>Simple mobility and recovery strategies between sessions</li>
			<li>Load management alongside training or work demands</li>
		</ul>
		<p>This ensures you are not reliant on treatment alone and can <strong>actively support your own recovery</strong>, especially if you are training frequently.</p>
	</ImageText>

	<ImageText reverse altBg eyebrow="Outcomes" heading="How we measure" highlight="your progress" image="/sports-massage/recovery-on-track.jpg" imageAlt="Athlete lying on a running track taking a break from training">
		<p>We track changes to ensure treatment is having a meaningful effect, particularly in relation to your ability to train and recover.</p>
		<p>This may include:</p>
		<ul>
			<li>Reduction in pain and muscle tension</li>
			<li>Improvements in flexibility and range of motion</li>
			<li>Changes in the quality of movements and muscle tension</li>
			<li>Improved recovery between training sessions</li>
			<li>Ability to maintain or progress training without setbacks</li>
		</ul>
		<p>Massage is most effective when these changes are clear and sustained over time.</p>
		<p><a href="/outcomes" class="section-link">Read More About Outcome Measures &rarr;</a></p>
	</ImageText>

	<ImageText eyebrow="Our patients" heading="Who we" highlight="help" image="/sports-massage/track-athlete-rest.jpg" imageAlt="Female athlete relaxing between training sessions" imagePosition="center top">
		<p>We work with a wide range of clients, with a particular focus on those placing regular physical demands on their bodies:</p>
		<ul>
			<li>Active individuals and athletes: Supporting training consistency, recovery, and performance</li>
			<li>Post-injury or post-surgical clients: Addressing residual tightness and restriction</li>
			<li>Parents: Managing physical strain from lifting and daily demands</li>
			<li>Our local population: Looking to maintain movement and reduce physical stress</li>
		</ul>
	</ImageText>

	<ImageText reverse altBg eyebrow="Our team" heading="Our" highlight="team" image="/sports-massage/outdoor-stretching.jpg" imageAlt="Athlete stretching outdoors before training" imagePosition="center top">
		<p>Our soft tissue team brings together highly experienced therapists with decades of combined expertise.</p>
		<p><strong>Deri Wilson</strong> specialises in soft tissue therapy and women's health, with over 18 years of experience supporting recovery and performance.</p>
		<p><a href="/meet-the-team" class="section-link">Read More About Deri &rarr;</a></p>
		<p><strong>Jonathan Lewis</strong> combines over 30 years of experience in sports massage with breathwork and movement coaching to support long-term change.</p>
		<p><a href="/meet-the-team" class="section-link">Read More About Jonathan &rarr;</a></p>
		<p><strong>Kellie Collar</strong> has over 25 years of experience and works extensively with athletes. She also provides practical guidance on stretching and self-management, including the use of tools such as massage devices and lacrosse balls.</p>
		<p><a href="/meet-the-team" class="section-link">Read More About Kellie &rarr;</a></p>
		<p><strong>Claire Benson</strong> provides specialist soft tissue and remedial therapy at our Audley Nightingale Place location.</p>
		<p><a href="/meet-the-team" class="section-link">Read More About Claire &rarr;</a></p>
	</ImageText>

	<ImageText eyebrow="Fees" heading="Pricing and" highlight="insurance" image="/sports-massage/runner-hydration.jpg" imageAlt="Runner cross-legged on the track taking a water break">
		<p>We offer a transparent fee structure that reflects our level of clinical expertise. We're also recognised by all major insurance providers, including Bupa and AXA Health.</p>
		<p><a href="/pricing" class="section-link">Pricing Information &rarr;</a></p>
	</ImageText>

	<section class="faq-section faq-section--alt">
		<div class="container">
			<div class="section-header"><h2>Frequently Asked Questions</h2></div>
			<div class="faq-list">
				{faqs.map((item) => (
					<details class="faq-item">
						<summary>{item.q}</summary>
						<div class="answer">{item.a}</div>
					</details>
				))}
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>
