---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
	title="in Clapham"
	highlight="Sports Massage"
	heroSubtitle="Targeted soft tissue therapy to improve muscle function, reduce tension, and support recovery from training, work, and daily life."
	breadcrumb="Sports Massage"
	seoTitle="Sports Massage in Clapham"
	seoDescription="Sports massage and soft tissue therapy in Clapham. Reduce muscle tension, support recovery, and improve movement with structured, clinician-led sessions."
	intro={[
		"Sports massage and soft tissue therapy focus on improving muscle function, reducing tension, and supporting recovery from training, work, and daily life.",
		"We take a structured approach where sessions address specific muscle and fascia restrictions developed through training loads, work, and posture.",
		"Our aim is to help you manage symptoms independently between appointments with clear self-care guidance alongside hands-on treatment.",
	]}
	whenHeading="When to consider"
	whenHighlight="sports massage"
	whenList={[
		"Muscle soreness or fatigue after training",
		"Persistent tightness affecting movement or performance",
		"Accumulated tension from high training volume or intensity",
		"Reduced flexibility or joint range of motion",
		"Ongoing tightness following injury or surgery",
		"Neck, shoulder, or back tension related to work or posture",
		"General physical stress and tension build-up",
	]}
	howHeading="How we"
	howHighlight="treat"
	howIntro="Techniques include a blend of hands-on work tailored to your needs, alongside practical guidance you can use between sessions."
	howList={[
		"Deep tissue massage",
		"Myofascial release and fascial work",
		"Trigger point therapy",
		"Soft tissue release techniques (STR)",
		"Assisted stretching",
		"Guidance on self-massage, mobility strategies, and load management",
	]}
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Active individuals and athletes",
		"Post-injury or post-surgical clients",
		"Parents managing physical strain",
		"Local population seeking movement maintenance",
	]}
	faqs={[
		{ q: "Is sports massage only for athletes?", a: "No. It is suitable for anyone with muscle tension, stiffness, or recovery needs." },
		{ q: "Will it be painful?", a: "Some techniques are uncomfortable, but treatment should always remain manageable and controlled." },
		{ q: "How often should I have a massage?", a: "Frequency depends on activity levels; regular training benefits from consistent sessions." },
		{ q: "Can massage help with tight hips or back pain?", a: "Yes, combined with self-management strategies to address the underlying drivers." },
		{ q: "Can I do anything between sessions?", a: "Yes, we provide guidance on massage balls and simple exercises to maintain progress." },
	]}
/>
