---
import ServicePage from '../../components/ServicePage.astro';
import ImageText from '../../components/ImageText.astro';

const physioPhotos = [
	{ src: '/physio/01-acupuncture.jpg', alt: 'Close-up of acupuncture needles' },
	{ src: '/physio/02-feet.jpg', alt: 'Feet on a foam roller during rehab' },
	{ src: '/physio/03-ems.jpg', alt: 'EMS electrodes on the quads' },
	{ src: '/physio/04-archery.jpg', alt: 'Archery, movement and control' },
];
---
<ServicePage
	title="in Clapham"
	highlight="Physiotherapy"
	heroSubtitle="Evidence-led physiotherapy that helps you understand how your body moves, why things have gone wrong, and what needs to change."
	breadcrumb="Physiotherapy"
	seoTitle="Physiotherapy in Clapham"
	seoDescription="Evidence-led physiotherapy in Clapham, London. From injury recovery to long-term condition management, we help you move better, feel stronger and return to what you love."
	marqueeImages={physioPhotos}
	intro={[
		"Pain, injury, or loss of function can change how you move, and how you live.",
		"At Balance, physiotherapy is about more than symptom relief. It's about understanding how your body moves, why things have gone wrong, and what needs to change to get you back to full capacity.",
		"We take a clinical, evidence-led approach to every case. From your first session, we assess how you move, not just where it hurts, then build a plan around your goals, your lifestyle, and your starting point.",
		"Whether you're recovering from injury, managing a long-term condition, or aiming to perform at a higher level, we meet you where you are and guide you forward.",
	]}
	introImage="/physio/body-1.jpg"
	whenHeading="When to consider"
	whenHighlight="physiotherapy"
	whenIntro="You don't need to wait for things to get worse. Physiotherapy can help if you're dealing with:"
	whenList={[
		"Ongoing back or neck pain, including sciatica",
		"Sports injuries",
		"Training setbacks - not meeting your running or cycling goals",
		"Joint pain or stiffness in the shoulder, knee, or hip",
		"Difficulty moving after surgery or injury",
		"Balance, coordination, or neurological issues",
		"Headaches linked to tension or posture",
		"Pelvic health or developmental concerns",
		"Dizziness - Vestibular Issues",
	]}
	whenImage="/physio/body-2.jpg"
	howHeading="How we"
	howHighlight="work"
	howIntro="Everything we do is built around one principle: helping you move better. Your treatment may include:"
	howList={[
		"Hands-on therapy to restore movement",
		"Targeted exercise to rebuild strength and control",
		"Progressive loading to prepare you for real-world demands",
		"Clear education so you understand your condition and recovery",
	]}
	howImage="/physio/body-3.jpg"
	whoHeading="Who we"
	whoHighlight="help"
	whoIntro="We work with people across a wide range of needs and experience levels."
	whoList={[
		"Individuals dealing with everyday pain or stiffness",
		"People like me and top athletes managing injury or performance",
		"Post-surgical patients rebuilding strength and function",
		"Children and young people with developmental or sports-related concerns",
		"Adults managing complex or long-term conditions",
	]}
	whoImage="/physio/body-4.jpg"
	faqs={[
		{ q: "Do I need a GP referral?", a: "No. You can book directly with us." },
		{ q: "What should I wear?", a: "Comfortable clothing that allows us to assess the area being treated." },
		{ q: "How many sessions will I need?", a: "This depends on your condition. After your first session, we'll give you a clear plan." },
		{ q: "Can I use my private health insurance?", a: "We recommend everyone checks with their own medical insurance provider with regards to their cover" },
		{ q: "What's the difference between a physiotherapist and a consultant physiotherapist?", a: "Consultant physiotherapists have advanced training and extensive experience managing complex cases. In their specialist area." },
	]}
>
	<Fragment slot="before-faq">
		<ImageText
			eyebrow="Pricing & insurance"
			heading="A transparent fee"
			highlight="structure"
			image="/physio/body-5.jpg"
			imageAlt="Accessible care, getting ready to train"
		>
			<p>We offer a transparent fee structure that reflects our level of clinical expertise. We're also recognised by all major insurance providers, including Bupa and AXA PPP Health.</p>
		</ImageText>

		<ImageText
			eyebrow="How we measure your progress"
			heading="We don't"
			highlight="guess"
			reverse
			altBg
			image="/physio/body-6.jpg"
			imageAlt="Hands-on treatment with a patient"
		>
			<p>From your first session, we establish a clear baseline of how you move, function, and feel. As you progress, we regularly reassess, looking at strength, mobility, pain, and what you can actually do day-to-day.</p>
			<p>This keeps your treatment focused and accountable.</p>
			<p>For you, that means:</p>
			<ul>
				<li>Clear evidence that you're improving</li>
				<li>A plan that adapts as you progress</li>
				<li>Confidence in your return to sport, work, or daily life</li>
			</ul>
		</ImageText>

		<ImageText
			eyebrow="Our clinical team"
			heading="Matched to"
			highlight="your needs"
			image="/physio/body-7.jpg"
			imageAlt="A collaborative team approach"
		>
			<p>Our physiotherapy team is made up of highly experienced clinicians with specialist areas of expertise.</p>
			<p>You'll be matched with the right practitioner for your needs, whether that's a complex spinal condition, a sports injury, or a long-term neurological issue.</p>
			<p>We work collaboratively, drawing on the depth of experience across the team to ensure your care is both precise and considered.</p>
		</ImageText>
	</Fragment>
</ServicePage>
