---
import ServicePage from '../../components/ServicePage.astro';
---
<ServicePage
	title="in Clapham"
	highlight="Strength & Conditioning"
	heroSubtitle="Structured, personalised strength training to improve health, performance, and long-term resilience — whatever your starting point."
	breadcrumb="Strength & Conditioning"
	seoTitle="Strength & Conditioning in Clapham"
	seoDescription="Strength and conditioning coaching in Clapham. Structured, personalised training for health, performance, injury recovery, and long-term resilience."
	intro={[
		"Strength and conditioning is for everyone. At Balance, we provide structured, personalised strength training to improve health, performance, and long-term resilience.",
		"Whether your goal is improving quality of life, returning to activity after injury, training for an event, or developing strength through different stages of life, we build a plan that fits.",
		"If movement limitations are present, these are addressed first — so training builds on a solid foundation.",
	]}
	whenHeading="When to consider"
	whenHighlight="S&C"
	whenIntro="You may benefit from structured strength training if you:"
	whenList={[
		"Feel weaker or less capable than desired in daily life",
		"Are not progressing despite regular training",
		"Want to return to exercise safely after injury or illness",
		"Experience recurring niggles or minor injuries",
		"Are preparing for a specific goal (e.g. marathon, trekking, performance)",
		"Want to build strength through life stages such as menopause or ageing",
	]}
	howHeading="How we"
	howHighlight="work"
	howIntro="Our approach focuses on:"
	howList={[
		"Movement quality and control",
		"Strength development through progressive loading",
		"Technique in key lifts (squat, deadlift, press)",
		"Building work capacity and resilience",
		"Integrating holistic concepts (nutrition, breathing) into lifestyle",
	]}
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Local population improving strength, energy, and quality of life",
		"Veterans maintaining independence, bone health, and resilience",
		"Athletes and active individuals preparing for events or recovering from injury",
		"People in recovery transitioning from rehabilitation to full training",
		"Busy professionals building physical resilience alongside work demands",
	]}
	faqs={[
		{ q: "Do I need to be fit to start?", a: "No. Training is tailored to your current level." },
		{ q: "Is this the same as going to the gym?", a: "No. Sessions are coached, structured, and focused on long-term progression rather than short-term intensity." },
		{ q: "Can I train if I\'ve had an injury?", a: "Yes. We regularly work with individuals returning from injury, often alongside physiotherapy." },
		{ q: "What kind of training will I do?", a: "A mix of resistance training, movement and bodyweight work, and conditioning exercises tailored to your goals." },
		{ q: "How many sessions will I need?", a: "This depends on your goals. Some people attend short-term, others train long-term." },
	]}
/>
