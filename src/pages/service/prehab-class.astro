---
import ServicePage from '../../components/ServicePage.astro';

const sliderImages = [
	{ src: '/prehab-class/slider-IMG_3921.jpg', alt: 'Agility training at the Balance Clapham clinic' },
	{ src: '/prehab-class/athletes-celebrating.jpg', alt: 'Group of athletes celebrating after a session' },
	{ src: '/prehab-class/yoga-pilates-equipment.jpg', alt: 'Foam rollers, resistance bands and fitballs' },
	{ src: '/prehab-class/slider-IMG_9461.webp', alt: 'Strength and mobility equipment at the Clapham clinic' },
	{ src: '/prehab-class/unrolling-yoga-mat.jpg', alt: 'Unrolling a mat before a session' },
	{ src: '/prehab-class/slider-IMG_1670.jpg', alt: 'Foam roller and mobility tools' },
	{ src: '/prehab-class/elderly-legs-mats.jpg', alt: 'Prehab class accessible to all ages' },
	{ src: '/prehab-class/slider-sportsinjury-physio.jpg', alt: 'Physiotherapist-led rehabilitation session' },
	{ src: '/prehab-class/slider-steph.webp', alt: 'Prehab coaching at Balance Physio Clapham' },
];
---
<ServicePage
	title="in Clapham"
	highlight="Prehab Class"
	heroSubtitle="A physiotherapist-led session focused on reducing injury risk and improving movement quality, whatever your starting point."
	breadcrumb="Prehab Class"
	seoTitle="Prehab Class in Clapham"
	seoDescription="Physiotherapist-led prehab class in Clapham. Build strength, mobility, and movement control to reduce injury risk and prepare for your next goal."
	marqueeImages={sliderImages}
	intro={[
		"Our Prehab Class is a physiotherapist-led session focused on reducing injury risk and improving movement quality.",
		"Prehab means preparation, it prepares you for your next stage, whether that\'s training, surgery, sport, or simply moving better day to day.",
		"It doesn\'t matter if you\'ve never exercised before. The class is designed to meet you where you are and build from there.",
	]}
	introImage="/prehab-class/athletes-celebrating.jpg"
	whenHeading="When to consider"
	whenHighlight="prehab"
	whenIntro="You may benefit if you:"
	whenList={[
		"Experience recurring niggles during or after exercise",
		"Have been asked by a surgical team to get fit before a procedure",
		"Feel restricted or tight in certain movements",
		"Have an injury history and want to reduce recurrence",
		"Feel performance is limited by movement quality",
		"Are preparing for a specific sport or event",
	]}
	whenImage="/prehab-class/unrolling-yoga-mat.jpg"
	howHeading="What the"
	howHighlight="class involves"
	howIntro="Sessions focus on:"
	howList={[
		"Mobility and joint range of movement",
		"Strength in commonly undertrained areas",
		"Movement control and coordination",
		"Stability through the trunk and lower limb",
		"Sport-specific preparation where relevant",
	]}
	howImage="/prehab-class/yoga-pilates-equipment.jpg"
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Gym users supporting strength training",
		"Patients recovering from injury or operations",
		"Patients preparing for operative procedures",
		"Runners and field athletes",
		"Active individuals reducing injury risk",
		"Office-based professionals counteracting stiffness",
	]}
	whoImage="/prehab-class/elderly-legs-mats.jpg"
	faqs={[
		{ q: "What is prehab?", a: "Prehabilitation focuses on reducing injury risk by improving strength, mobility, and movement control before problems develop." },
		{ q: "Do I need to be highly trained?", a: "No. The class is suitable for anyone who is active or looking to become more active." },
		{ q: "Can I attend if I\'m currently injured?", a: "If you have an acute injury, we recommend an initial physiotherapy assessment first." },
		{ q: "What should I wear?", a: "Comfortable clothing that allows you to move freely." },
		{ q: "How is this different from a fitness class?", a: "The class is led by a physiotherapist and focuses on movement quality and injury risk, rather than intensity alone." },
	]}
/>
