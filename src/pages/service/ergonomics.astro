---
import ServicePage from '../../components/ServicePage.astro';

const sliderImages = [
	{ src: '/ergonomics/slider-IMG_2045.webp', alt: 'Ergonomic equipment at the Balance Clapham clinic' },
	{ src: '/ergonomics/workplace-businessman.jpg', alt: 'Ergonomic office setup with chair, keyboard and monitor' },
	{ src: '/ergonomics/slider-file-29-11-2015.jpeg', alt: 'Home ergonomic assessment in progress' },
	{ src: '/ergonomics/typing-hands.jpg', alt: 'Hands typing on a keyboard' },
	{ src: '/ergonomics/slider-balance-interior.jpg', alt: 'Balance Physio Clapham interior' },
	{ src: '/ergonomics/childrens-study-room.jpg', alt: 'Children\'s study space at home' },
	{ src: '/ergonomics/slider-ergonomics-studio.webp', alt: 'Ergonomics studio at Balance Physio Clapham' },
	{ src: '/ergonomics/office-desk.jpg', alt: 'Open-plan office workspace' },
];
---
<ServicePage
	title="in Clapham"
	highlight="Ergonomics"
	heroSubtitle="Pain at your desk is not something you have to accept. Back, neck and shoulder issues are often driven by how your workspace is set up and how you move within it."
	breadcrumb="Ergonomics"
	seoTitle="Ergonomics in Clapham"
	seoDescription="Ergonomic assessments in Clapham and online. Reduce back, neck and shoulder pain at work with practical workspace advice and targeted exercises."
	marqueeImages={sliderImages}
	intro={[
		"Pain at your desk is not something you have to accept. Back pain, neck tension, shoulder blade niggles and shoulder discomfort are often driven by how your workspace is set up and how you move within it.",
		"Ergonomics is about understanding how your body interacts with your working environment, identifying why symptoms develop, and implementing practical, sustainable solutions.",
	]}
	introImage="/ergonomics/workplace-businessman.jpg"
	whenHeading="When to consider"
	whenHighlight="ergonomics support"
	whenIntro="You may benefit from an assessment if you are experiencing:"
	whenList={[
		"Back pain during or after work",
		"Neck stiffness or tension linked to screen use",
		"Shoulder discomfort from prolonged sitting or poor setup",
		"Headaches associated with desk posture",
		"Discomfort when working from home or using laptops",
		"Fatigue or reduced productivity due to physical strain",
	]}
	whenImage="/ergonomics/typing-hands.jpg"
	howHeading="How we"
	howHighlight="work"
	howIntro="Assessments are offered in person or virtually and may include:"
	howList={[
		"Video analysis of your workspace to identify symptom drivers",
		"Clear explanation of why pain has developed",
		"Immediate setup adjustments to reduce strain",
		"Guidance on chairs, desks, keyboards, monitor height, and supports",
		"Simple, implementable changes for home or work",
		"Targeted exercises addressing movement habits",
	]}
	howImage="/ergonomics/office-desk.jpg"
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Office-based professionals",
		"Remote workers",
		"Hybrid workers",
		"Individuals with recurring musculoskeletal pain",
		"Parents balancing multiple work environments",
		"Anyone seeking improved comfort and productivity",
	]}
	whoImage="/ergonomics/childrens-study-room.jpg"
	faqs={[
		{ q: "Are virtual assessments available?", a: "Yes, including a workspace review via video." },
		{ q: "Do I need expensive equipment?", a: "Not necessarily. Many issues resolve through simple adjustments." },
		{ q: "Can this help with back and neck pain?", a: "Yes. Poor setup and movement habits commonly contribute to both." },
		{ q: "Will I get exercises?", a: "Yes. Targeted exercises address the movement patterns contributing to your pain." },
		{ q: "Can you help with my home setup?", a: "Yes, even with limited space or equipment." },
	]}
/>
