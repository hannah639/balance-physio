---
import ServicePage from '../../components/ServicePage.astro';

const sliderImages = [
	{ src: '/anti-gravity-treadmill/slider-gtrainer.webp', alt: 'AlterG Anti-Gravity Treadmill at Balance Physio Clapham' },
	{ src: '/anti-gravity-treadmill/slider-alter-g-trainer-running-london.webp', alt: 'Runner training on the AlterG treadmill' },
	{ src: '/anti-gravity-treadmill/slider-p200.webp', alt: 'AlterG P200 anti-gravity treadmill' },
	{ src: '/anti-gravity-treadmill/slider-IMG-4866.jpg', alt: 'AlterG treadmill in use at the clinic' },
	{ src: '/anti-gravity-treadmill/slider-session.webp', alt: 'AlterG rehabilitation session' },
];
---
<ServicePage
	title="in Clapham"
	highlight="AlterG Anti-Gravity Treadmill"
	introYoutubeId="LeHksjmPi3k"
	heroSubtitle="Rehab doesn\\'t have to mean stopping. The AlterG Anti-Gravity Treadmill allows you to walk or run with reduced body weight, so you can stay on track whilst your body recovers."
	breadcrumb="AlterG Anti-Gravity Treadmill"
	seoTitle="AlterG Anti-Gravity Treadmill in Clapham"
	seoDescription="AlterG Anti-Gravity Treadmill in Clapham. Walk or run with reduced body weight to keep training through injury, rebuild strength and return to sport safely."
	marqueeImages={sliderImages}
	intro={[
		"The AlterG uses air pressure technology to reduce body weight during walking or running, allowing load control through the joints from normal weight-bearing down to 20%.",
		"It lets you continue training despite injury, move without pain when full weight-bearing isn\\'t possible, and rebuild strength, fitness and confidence gradually in a controlled environment.",
	]}
	introImage="/anti-gravity-treadmill/gtrainer3.webp"
	whenHeading="When the AlterG"
	whenHighlight="can help"
	whenList={[
		"Sports injuries or returning to running",
		"Post-fracture recovery (post-boot or crutches)",
		"Musculoskeletal injuries of the knee, hip, or ankle",
		"Back pain affecting walking or running",
		"Post-surgery rehab such as ACL or joint replacement",
		"Neurological conditions affecting gait or balance",
		"Reduced mobility or walking confidence",
		"Weight reduction programmes",
	]}
	whenImage="/anti-gravity-treadmill/viax-man-run-rear.webp"
	howHeading="How we"
	howHighlight="use it"
	howIntro="Sessions begin with an induction to discuss your goals. Treatment adjusts load, speed, and progression based on individual needs — reducing load for rehabilitation and increasing volume for performance goals. Live visual feedback is used to assess movement patterns."
	howList={[
		"Goal-setting induction on first visit",
		"Controlled body-weight reduction from 100% down to 20%",
		"Progressive load, speed, and volume adjustments",
		"Live visual feedback on gait and movement",
		"Integration with wider physiotherapy or training plans",
	]}
	howImage="/anti-gravity-treadmill/via-woman-walk.webp"
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Runners and athletes maintaining fitness during injury",
		"Those training for advanced cardiovascular fitness",
		"Post-surgical patients rebuilding strength",
		"People returning to exercise after a break",
		"Those managing joint pain and long-term conditions",
		"Veterans maintaining activity with reduced joint load",
	]}
	whoImage="/anti-gravity-treadmill/viax-man-run-front.webp"
	faqs={[
		{ q: "Do I need a referral?", a: "No. You can book directly online. An induction is recommended for your first visit." },
		{ q: "What should I wear?", a: "Carry clean running shoes separately. Wear tight shorts; the clinic provides AlterG shorts to wear over them." },
		{ q: "Can I use it for running training?", a: "Yes. It is commonly used to maintain or increase training volume and speed while reducing impact." },
		{ q: "Is it suitable after surgery?", a: "Yes. It is often used for a structured return to weight-bearing activity." },
		{ q: "How often should I use it?", a: "It depends on your goals. We provide guidance based on your individual situation." },
	]}
/>
