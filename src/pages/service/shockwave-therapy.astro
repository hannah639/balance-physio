---
import ServicePage from '../../components/ServicePage.astro';

const sliderImages = [
	{ src: '/shockwave-therapy/shockwave-procedure.jpg', alt: 'Shockwave therapy being applied to the leg' },
	{ src: '/shockwave-therapy/back-massage.jpg', alt: 'Shockwave device used on the back' },
	{ src: '/shockwave-therapy/close-up-medical.jpg', alt: 'Close-up of shockwave therapy on the arm' },
	{ src: '/shockwave-therapy/male-patient.jpg', alt: 'Patient receiving extracorporeal shockwave therapy on the leg' },
	{ src: '/shockwave-therapy/rehabilitologist.jpg', alt: 'Rehabilitologist treating a patient with shockwave' },
	{ src: '/shockwave-therapy/massage-session.jpg', alt: 'Shockwave device used during a treatment session' },
	{ src: '/shockwave-therapy/screen-shot-2019.webp', alt: 'Shockwave therapy at Balance Physio Clapham' },
];
---
<ServicePage
	title="in Clapham"
	highlight="Shockwave Therapy"
	heroSubtitle="For persistent tendon and soft tissue problems that haven\'t responded to rest, exercise, or standard treatment."
	breadcrumb="Shockwave Therapy"
	seoTitle="Shockwave Therapy in Clapham"
	seoDescription="Shockwave therapy in Clapham for stubborn tendon pain and soft tissue injuries. Restart healing as part of a structured rehabilitation plan."
	marqueeImages={sliderImages}
	intro={[
		"When pain lingers, it usually means something hasn\'t fully healed. Shockwave therapy is designed for exactly that, persistent tendon and soft tissue problems that haven\'t responded to rest, exercise, or standard treatment.",
		"At Balance, we use shockwave as part of a wider, structured rehabilitation plan. The goal isn\'t just to reduce pain, but to restart the healing process so you can move forward.",
		"Treatment is delivered alongside clear diagnosis and loading advice, ensuring the tissue recovers properly rather than simply masking symptoms.",
	]}
	introImage="/shockwave-therapy/close-up-medical.jpg"
	whenHeading="When to consider"
	whenHighlight="shockwave"
	whenIntro="Common conditions we treat with shockwave include:"
	whenList={[
		"Plantar fasciitis (heel pain, especially first steps in the morning)",
		"Achilles tendinopathy",
		"Patellar tendon pain (below the knee)",
		"Tennis or golfer\'s elbow",
		"Shoulder tendon pain or calcification",
		"Lateral hip pain (greater trochanteric pain)",
	]}
	whenImage="/shockwave-therapy/back-massage.jpg"
	howHeading="How it"
	howHighlight="works"
	howIntro="Shockwave therapy uses controlled acoustic pulses delivered directly into the affected tissue. This stimulates a response in the body that helps:"
	howList={[
		"Improve blood flow to the area",
		"Reduce pain sensitivity",
		"Encourage tissue repair",
		"Delivered by a handheld device applied to the affected area",
		"Most people require a short course spaced over a few weeks",
	]}
	howImage="/shockwave-therapy/shockwave-procedure.jpg"
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Runners and athletes with persistent tendon injuries",
		"People dealing with long-standing heel or elbow pain",
		"Individuals who haven\'t responded to previous treatment",
		"Those seeking to avoid injections or surgery where possible",
	]}
	whoImage="/shockwave-therapy/massage-session.jpg"
	faqs={[
		{ q: "Is shockwave therapy painful?", a: "It can be uncomfortable, but the intensity is adjusted to remain tolerable." },
		{ q: "How many sessions will I need?", a: "Most people benefit from a short course of 3–5 sessions." },
		{ q: "Are there any side effects?", a: "Mild soreness, redness, or bruising can occur temporarily after treatment." },
		{ q: "Can I exercise afterwards?", a: "We usually recommend reducing heavy loading for 48 hours, then progressing as advised." },
		{ q: "How is this different from an injection?", a: "Shockwave stimulates healing and is pro-inflammatory, whereas injections typically aim to reduce inflammation." },
		{ q: "Do I need a referral?", a: "Yes, we require a referral from a consultant, unless you are seeing Steve, our Podiatrist, who can confirm diagnosis with Ultrasound." },
	]}
/>
