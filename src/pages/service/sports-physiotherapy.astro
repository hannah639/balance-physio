---
import ServicePage from '../../components/ServicePage.astro';

const sportsPhotos = [
	{ src: '/sports-physio/01.jpg', alt: 'Athlete training' },
	{ src: '/sports-physio/02.jpg', alt: 'Judo group' },
	{ src: '/sports-physio/03.jpg', alt: 'Skiing group' },
	{ src: '/sports-physio/04.jpg', alt: 'Beach volleyball team' },
	{ src: '/sports-physio/05.jpg', alt: 'Skiing on the slope' },
	{ src: '/sports-physio/06.jpg', alt: 'Badminton session' },
	{ src: '/sports-physio/07.jpg', alt: 'Tennis player serving' },
	{ src: '/sports-physio/08.jpg', alt: 'Tennis backhand' },
];
---
<ServicePage
	title="in Clapham"
	highlight="Sports Physiotherapy"
	heroSubtitle="Clinical, evidence-led care to keep you training, competing and performing at the level you want."
	breadcrumb="Sports Physiotherapy"
	seoTitle="Sports Physiotherapy in Clapham"
	seoDescription="Specialist sports physiotherapy in Clapham, London. From amateur to elite, we assess how you move under load, rebuild strength, and get you safely back to sport."
	marqueeImages={sportsPhotos}
	marqueeSpeed={40}
	intro={[
		"Sport places specific individual demands on the body. Whether you are training, competing, or simply trying to stay active, injury or pain can quickly affect your confidence and performance.",
		"We take a clinical, evidence-led approach to every case. From your first session, we assess how you move under load, how your body responds to training, and where the breakdown has occurred.",
		"We then build a structured plan around your goals, your sport, and your starting point.",
	]}
	introImage="/sports-physio/hero-running.jpg"
	whenHeading="When to consider"
	whenHighlight="sports physio"
	whenList={[
		"Ongoing pain that returns when you increase training",
		"Reduced performance or difficulty progressing in your sport",
		"Acute sports injuries such as muscle strains or ligament sprains",
		"Tendon issues linked to running, jumping, or repetitive loading",
		"Growth-related injuries in children and adolescents",
		"Recovery following surgery or time away from sport",
		"Movement limitations affecting strength, speed or control",
	]}
	whenImage="/sports-physio/hero-swimming.jpg"
	howList={[
		"Hands-on therapy to reduce pain and restore movement",
		"Targeted exercise to rebuild strength, control and coordination",
		"Progressive loading to prepare you for sport-specific demands",
		"Movement analysis to identify inefficiencies and reduce injury risk",
		"Clear education so you understand your condition and recovery",
	]}
	howImage="/sports-physio/hero-cricket.jpg"
	whoList={[
		"Adults returning to sport after injury or time away",
		"Athletes looking to stay consistent and pain-free",
		"High-performing athletes aiming to optimise performance",
		"Children and young athletes managing growth and training demands",
		"Parents seeking safe and structured support for their child's development",
		"Individuals wanting to build strength, resilience and confidence",
	]}
	whoImage="/sports-physio/hero-skiing.jpg"
	faqs={[
		{ q: "Do I need a GP referral?", a: "No. You can book directly with us." },
		{ q: "Can children have sports physiotherapy?", a: "Yes. We regularly work with young athletes, focusing on safe development, injury management and long-term progression." },
		{ q: "What should I wear?", a: "Comfortable clothing that allows us to assess movement and, where relevant, sport-specific activity." },
		{ q: "How many sessions will I need?", a: "This depends on your injury and goals. After your first session, we'll give you a clear plan." },
		{ q: "When can I return to sport?", a: "We use clear criteria based on strength, movement and performance to guide your return safely." },
	]}
/>
