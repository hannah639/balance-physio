---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import BookingCTA from '../../components/BookingCTA.astro';

const services = [
	{ title: 'Physiotherapy', blurb: 'Evidence-led physiotherapy to help you understand how your body moves and what needs to change.', href: '/service/physiotherapy' },
	{ title: 'Sports Physiotherapy', blurb: 'Clinical care for athletes, from amateur to elite, to keep you training, competing and performing.', href: '/service/sports-physiotherapy' },
	{ title: 'Paediatric Sports Physiotherapy', blurb: 'Consultant youth physiotherapy for young athletes and active children. Growing bodies need a unique approach.', href: '/service/paediatric-sports-physiotherapy' },
	{ title: 'Osteopathy', blurb: 'Hands-on osteopathy combined with nutritional support, treating the whole body, not just the symptoms.', href: '/service/osteopathy' },
	{ title: 'Sports Massage', blurb: 'Targeted soft tissue therapy to ease tension, speed recovery and improve performance.', href: '/service/sports-massage' },
	{ title: 'Shockwave Therapy', blurb: 'Non-invasive treatment for stubborn tendon and soft tissue injuries.', href: '/service/shockwave-therapy' },
	{ title: 'Prehab Class', blurb: 'Group-led movement work to prevent injury and build resilience before problems arise.', href: '/service/prehab-class' },
	{ title: 'Neurological Rehabilitation', blurb: 'Specialist rehab for stroke, MS, Parkinson\'s and other neurological conditions.', href: '/service/neurological-rehabilitation' },
	{ title: 'Vojta Therapy', blurb: 'A specialist neurological technique to restore automatic movement patterns.', href: '/service/vojta-therapy' },
	{ title: "Women's Health", blurb: 'Specialist pelvic health care for women, from Mummy MOTs to long-term support.', href: '/service/womens-health' },
	{ title: "Men's Health", blurb: 'Specialist pelvic health care for men at every life stage.', href: '/service/mens-health' },
	{ title: 'Podiatry', blurb: 'Expert foot and lower limb care, including musculoskeletal and chiropody services.', href: '/service/podiatry' },
	{ title: 'Strength & Conditioning', blurb: '1-to-1 coaching to build strength, resilience and performance.', href: '/service/strength-conditioning' },
	{ title: 'LIFT, Weight Training Club', blurb: 'Supported weight training club for building confidence and strength.', href: '/service/lift-weight-training-club' },
	{ title: 'Bike Fitting & Running Analysis', blurb: 'Dial in your position and gait to ride and run faster, for longer, injury-free.', href: '/service/bike-fitting-running-analysis' },
	{ title: 'Hydrotherapy', blurb: 'Water-based rehabilitation for gentle, effective recovery.', href: '/service/hydrotherapy' },
	{ title: 'Psychological Wellness', blurb: 'Support for the mental side of recovery, pain and performance.', href: '/service/psychological-wellness' },
	{ title: 'Anti-Gravity Treadmill', blurb: 'Alter-G treadmill training for safe, progressive return-to-running.', href: '/service/anti-gravity-treadmill' },
	{ title: 'Ergonomics', blurb: 'Workspace assessments at home, at work or at our clinic.', href: '/service/ergonomics' },
	{ title: 'TMJ & Jaw Pain', blurb: 'Specialist treatment for jaw pain, tension and dysfunction.', href: '/service/tmj-and-jaw-pain' },
	{ title: 'Physiotherapy Prescribing', blurb: 'Medication and injection prescribing from our advanced practitioners.', href: '/service/physiotherapy-prescribing' },
	{ title: 'Outcome Measures', blurb: 'How we track and prove progress from your first session.', href: '/service/outcome-measures' },
];
---
<Layout
	title="Services"
	description="Explore every service at Balance Performance Physiotherapy, from physiotherapy and osteopathy to sports massage, podiatry, strength training and more."
>
	<PageHero
		title="Services"
		highlight="Our"
		subtitle="27 specialists, one roof. Explore everything we offer to help you move, recover and perform."
		breadcrumb="Services"
	/>

	<section class="link-grid-section">
		<div class="container">
			<div class="link-grid">
				{services.map((s) => (
					<a href={s.href} class="link-grid-item">
						<h3>{s.title}</h3>
						<p>{s.blurb}</p>
						<span class="arrow">Learn more &rsaquo;</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>
