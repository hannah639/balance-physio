---
import { siteSettings as settings } from '../data/site-settings.js';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookiesBanner from '../components/CookiesBanner.astro';
import VideoHero from '../components/VideoHero.astro';
import Hero from '../components/Hero.astro';
import ActivitiesSlider from '../components/ActivitiesSlider.astro';
import Features from '../components/Features.astro';
import Conditions from '../components/Conditions.astro';
import Approach from '../components/Approach.astro';
import FacilitiesBanner from '../components/FacilitiesBanner.astro';
import Team from '../components/Team.astro';
import QuoteBanner from '../components/QuoteBanner.astro';
import Testimonials from '../components/Testimonials.astro';
import BookingCTA from '../components/BookingCTA.astro';

const pageTitle = settings.title;
const pageDescription = settings.description || '';
const siteUrl = settings.siteUrl;
const ogImageUrl = settings.ogImage ? `${siteUrl}${settings.ogImage}` : null;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const gaId = settings.gaId || '';
const gtmId = settings.gtmId || '';

// Build JSON-LD structured data for Google
const jsonLd = settings.businessName ? {
	'@context': 'https://schema.org',
	'@type': settings.businessType || 'LocalBusiness',
	name: settings.businessName,
	...(pageDescription && { description: pageDescription }),
	url: siteUrl,
	...(ogImageUrl && { image: ogImageUrl }),
	...(settings.phone && { telephone: settings.phone }),
	...(settings.email && { email: settings.email }),
	...(settings.priceRange && { priceRange: settings.priceRange }),
	...((settings.streetAddress || settings.city) && {
		address: {
			'@type': 'PostalAddress',
			...(settings.streetAddress && { streetAddress: settings.streetAddress }),
			...(settings.city && { addressLocality: settings.city }),
			...(settings.region && { addressRegion: settings.region }),
			...(settings.postalCode && { postalCode: settings.postalCode }),
			...(settings.country && { addressCountry: settings.country }),
		},
	}),
	...(settings.latitude && settings.longitude && {
		geo: {
			'@type': 'GeoCoordinates',
			latitude: settings.latitude,
			longitude: settings.longitude,
		},
	}),
	...(settings.openingHours?.length && {
		openingHoursSpecification: settings.openingHours.map((h) => ({
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: h.dayOfWeek,
			opens: h.opens,
			closes: h.closes,
		})),
	}),
	...(settings.sameAs?.length && { sameAs: settings.sameAs }),
} : null;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		{pageDescription && <meta name="description" content={pageDescription} />}
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={pageTitle} />
		{pageDescription && <meta property="og:description" content={pageDescription} />}
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		{pageDescription && <meta name="twitter:description" content={pageDescription} />}
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

		{jsonLd && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		)}
	</head>
	<body>
		{gtmId && (
			<noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${gtmId}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
		)}
		<div class="bp-page">
			<Header />
			<VideoHero />
			<Hero />
			<ActivitiesSlider />
			<Features />
			<Conditions />
			<Approach />
			<FacilitiesBanner />
			<Team sliderRow />
			<QuoteBanner />
			<Testimonials />
			<BookingCTA />
			<Footer />
		</div>
		<CookiesBanner gaId={gaId} gtmId={gtmId} />

		<!-- Trustindex Google reviews badge (small floating widget). Renders
		     site-wide via the loader script — Trustindex positions it itself. -->
		<script defer async src="https://cdn.trustindex.io/loader.js?d31b89f7085c92783a46663d571"></script>

		<script is:inline>
			(function() {
				var slider = document.getElementById('activitiesSlider');
				if (!slider) return;
				setInterval(function() {
					var maxScroll = slider.scrollWidth - slider.clientWidth;
					if (slider.scrollLeft >= maxScroll - 10) {
						slider.scrollTo({ left: 0, behavior: 'smooth' });
					} else {
						slider.scrollBy({ left: 340, behavior: 'smooth' });
					}
				}, 3000);
			})();
		</script>
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

	html, body { margin: 0; padding: 0; }

	.bp-page {
		--primary: #3d5a6e;
		--primary-dark: #2c4356;
		--primary-light: #5a7d8f;
		--accent: #e87722;
		--accent-hover: #d06618;
		--cta: #3EBEDF;
		--cta-hover: #32a8c6;
		--primary-bg: #f4f6f7;
		--primary-bg-gradient: #e8edef;
		--accent-glow: rgba(44,197,190,0.25);
		--white: #ffffff;
		--black: #000000;
		--text: #1a1a1a;
		--text-muted: #555555;
		--border: #d8dee2;
		--card-shadow: 0 0 10px rgba(0,0,0,0.11);
		--radius: 15px;
		font-family: 'Inter', sans-serif;
		color: var(--text);
		line-height: 1.6;
	}
	.bp-page *, .bp-page *::before, .bp-page *::after { margin: 0; padding: 0; box-sizing: border-box; }
	.bp-page a { text-decoration: none; color: inherit; }
	.bp-page img { max-width: 100%; }
	.bp-page .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

	/* ── Buttons ── */
	.bp-page .btn-primary { padding: 10px 24px; border-radius: 50px; font-weight: 600; font-size: 14px; color: var(--white); background: var(--cta); border: none; cursor: pointer; transition: all .2s; }
	.bp-page .btn-primary:hover { background: var(--cta-hover); }
	.bp-page .btn-primary-lg { padding: 16px 36px; border-radius: 12px; font-weight: 600; font-size: 16px; color: var(--white); background: var(--cta); border: none; cursor: pointer; transition: all .2s; display: inline-block; }
	.bp-page .btn-primary-lg:hover { background: var(--cta-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(62,190,223,0.3); }

	/* ── Video Hero ── */
	.bp-page .video-hero { position: relative; width: 100%; height: 100vh; overflow: hidden; display: flex; align-items: center; justify-content: center; }
	.bp-page .video-hero video { position: absolute; top: 50%; left: 50%; min-width: 100%; min-height: 100%; transform: translate(-50%, -50%); object-fit: cover; z-index: 0; }
	.bp-page .video-hero-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.55); z-index: 1; }
	.bp-page .video-hero-content { position: relative; z-index: 2; text-align: center; color: var(--white); max-width: 900px; padding: 0 24px; }
	.bp-page .video-hero-content .subtitle { font-size: 14px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 24px; color: rgba(255,255,255,0.85); }
	.bp-page .video-hero-content h1.subtitle,
	.bp-page .video-hero-content .subtitle { font-size: 14px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; margin: 0 0 24px; color: rgba(255,255,255,0.85); line-height: 1.2; }
	.bp-page .video-hero-content h1,
	.bp-page .video-hero-content .hero-tagline { font-size: 56px; font-weight: 700; line-height: 1.15; margin: 0 auto 24px; letter-spacing: -1px; color: #ffffff; max-width: none; }
	.bp-page .video-hero-content p { font-size: 18px; color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto 40px; line-height: 1.7; }
	.bp-page .video-hero-content p.hero-tagline { font-size: 56px; font-weight: 700; line-height: 1.15; margin: 0 auto 24px; letter-spacing: -1px; color: #ffffff; max-width: none; }
	.bp-page .btn-book { display: inline-block; padding: 18px 48px; border-radius: 50px; font-size: 17px; font-weight: 600; border: none; cursor: pointer; background: var(--accent); color: var(--white); transition: all .3s; }
	.bp-page .btn-book:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(232,119,34,0.4); }
	.bp-page .video-hero-scroll { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 2; color: var(--white); font-size: 32px; opacity: 0.7; animation: bp-bounceDown 2s infinite; }
	@keyframes bp-bounceDown { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(10px); } }
	@media (max-width: 768px) { .bp-page .video-hero-content h1, .bp-page .video-hero-content p.hero-tagline { font-size: 32px; } .bp-page .video-hero-content h1.subtitle { font-size: 14px; } .bp-page .video-hero-content p { font-size: 16px; } }

	/* ── Hero ── */
	.bp-page .hero { position: relative; overflow: hidden; background: var(--primary-dark); padding: 100px 0 80px; color: var(--white); }
	.bp-page .hero::after { content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 50%; background: radial-gradient(circle at 85% 50%, var(--accent-glow) 0%, transparent 60%); pointer-events: none; }
	.bp-page .hero-content { position: relative; z-index: 2; text-align: center; max-width: 800px; margin: 0 auto; }
	.bp-page .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 50px; padding: 6px 16px; font-size: 13px; font-weight: 500; margin-bottom: 24px; color: rgba(255,255,255,0.8); }
	.bp-page .hero-badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cta); }
	.bp-page .hero h1, .bp-page .hero h2, .bp-page .hero .hero-title { font-size: 64px; font-weight: 800; line-height: 1.1; margin-bottom: 20px; letter-spacing: -2px; color: var(--white); }
	.bp-page .hero h1 .highlight, .bp-page .hero h2 .highlight, .bp-page .hero .hero-title .highlight { color: var(--accent); }
	.bp-page .hero p { font-size: 20px; color: rgba(255,255,255,0.75); max-width: 600px; margin: 0 auto 16px; }
	.bp-page .hero-stats { display: flex; justify-content: center; gap: 40px; margin: 40px 0; }
	.bp-page .hero-stat { text-align: center; }
	.bp-page .hero-stat .number { font-size: 36px; font-weight: 800; color: var(--accent); }
	.bp-page .hero-stat .label { font-size: 14px; color: rgba(255,255,255,0.7); }

	/* ── Problem/Approach ── */
	.bp-page .problem { padding: 100px 0; background: linear-gradient(135deg, #fdf4eb 0%, #faead7 100%); }
	/* On mobile the previous section (Conditions / .clinics) is light grey,
	   and .problem's peach gradient created a hard horizontal break right
	   at the join. Soften it by starting from the same neutral and easing
	   into the peach over the first ~25% of the section. */
	@media (max-width: 768px) {
		.bp-page .problem {
			background: linear-gradient(180deg,
				var(--primary-bg) 0%,
				#fdf4eb 18%,
				#faead7 100%);
		}
	}
	.bp-page .section-header { text-align: center; max-width: 700px; margin: 0 auto 60px; }
	.bp-page .section-header h2 { font-size: 42px; font-weight: 800; line-height: 1.2; margin-bottom: 16px; letter-spacing: -1px; }
	.bp-page .section-header p { font-size: 18px; color: var(--text-muted); }
	.bp-page .problem-grid { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 16px; align-items: start; }
	.bp-page .problem-arrow { display: flex; align-items: center; justify-content: center; font-size: 28px; color: var(--accent); padding-top: 120px; animation: bp-pulseRight 1.5s ease-in-out infinite; }
	@keyframes bp-pulseRight { 0%, 100% { transform: translateX(0); opacity: 0.6; } 50% { transform: translateX(6px); opacity: 1; } }
	.bp-page .problem-card { background: var(--white); border-radius: var(--radius); padding: 40px 32px; border: 1px solid var(--border); transition: transform .3s, box-shadow .3s; display: flex; flex-direction: column; }
	.bp-page .problem-card:hover { transform: translateY(-4px); box-shadow: var(--card-shadow); }
	.bp-page .problem-card.featured { background: var(--primary-dark); color: var(--white); border-color: var(--primary-dark); transform: translateY(-12px); box-shadow: 0 20px 40px rgba(0,0,0,0.2); padding: 40px 32px; }
	.bp-page .problem-card.featured:hover { transform: translateY(-16px); }
	.bp-page .problem-card.featured h3 { color: var(--white); }
	.bp-page .problem-card.featured p { color: rgba(255,255,255,0.75); }
	.bp-page .problem-card.featured .icon { background: var(--accent); }
	.bp-page .problem-card .step-label { font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; line-height: 1; display: flex; align-items: baseline; gap: 10px; order: 1; }
	.bp-page .problem-card.featured .step-label { color: rgba(255,255,255,0.65); }
	.bp-page .problem-card .step-num { font-size: 36px; font-weight: 800; color: var(--accent); line-height: 1; letter-spacing: -1.5px; }
	.bp-page .problem-card.featured .step-num { color: var(--cta); }
	.bp-page .problem-card .step-tag { display: block; font-size: 38px; font-weight: 800; line-height: 1.0; letter-spacing: -1.5px; color: var(--accent); margin-bottom: 24px; order: 2; }
	.bp-page .problem-card.featured .step-tag { color: var(--cta); }
	.bp-page .problem-card .step-row { display: flex; flex-direction: column; align-items: flex-start; margin-bottom: 0; order: 1; }
	.bp-page .problem-card .icon { width: 40px; height: 40px; border-radius: 10px; background: var(--accent); color: var(--white); display: flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: 16px; order: 3; opacity: 0.85; }
	.bp-page .problem-card h3 { font-size: 14px; font-weight: 600; line-height: 1.5; margin-bottom: 12px; color: var(--text-muted); order: 4; }
	.bp-page .problem-card.featured h3 { color: rgba(255,255,255,0.7); }
	.bp-page .problem-card p { font-size: 15px; color: var(--text-muted); line-height: 1.7; order: 5; }
	.bp-page .problem-card .bullet-list { list-style: none; margin-top: 20px; order: 6; }
	.bp-page .problem-card .bullet-list li { padding: 6px 0; font-size: 14px; display: flex; align-items: center; gap: 10px; }
	.bp-page .problem-card .bullet-list li::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
	.bp-page .problem-card.featured .bullet-list li::before { background: var(--cta); }
	.bp-page .problem .section-header h2 .highlight { color: var(--accent); }

	/* ── Image + Quote Banners ── */
	.bp-page .image-quote-section { position: relative; width: 100%; overflow: hidden; }
	.bp-page .image-banner { position: relative; width: 100%; height: 70vh; overflow: hidden; }
	.bp-page .image-banner img { width: 100%; height: 100%; object-fit: cover; display: block; }
	.bp-page .image-banner-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.55); display: flex; align-items: center; }
	.bp-page .image-banner-content { max-width: 700px; padding: 0 48px; color: var(--white); }
	.bp-page .image-banner-content h2 { font-size: 42px; font-weight: 800; margin-bottom: 20px; letter-spacing: -1px; }
	.bp-page .image-banner-content p { font-size: 17px; line-height: 1.8; color: rgba(255,255,255,0.85); margin-bottom: 32px; }
	.bp-page .btn-outline-white { display: inline-block; padding: 14px 36px; border-radius: 50px; font-size: 15px; font-weight: 600; border: 2px solid var(--white); color: var(--white); background: transparent; cursor: pointer; transition: all .3s; }
	.bp-page .btn-outline-white:hover { background: var(--white); color: var(--primary-dark); }
	.bp-page .image-banner-quote { height: 80vh; }
	.bp-page .image-quote-mark { font-size: 120px; line-height: 1; color: rgba(255,255,255,0.15); font-family: Georgia, serif; margin-bottom: -20px; }
	@media (max-width: 768px) {
		.bp-page .image-banner { height: 60vh; }
		.bp-page .image-banner-content { padding: 0 32px; }
		.bp-page .image-banner-content h2 { font-size: 28px; }
		.bp-page .image-banner-content p { font-size: 15px; line-height: 1.65; }
		.bp-page .image-banner-content .btn-outline-white { padding: 12px 28px; font-size: 14px; }
		.bp-page .image-banner-quote blockquote { font-size: 20px !important; }
	}

	/* ── Activities Slider ── */
	.bp-page .activities { padding: 100px 0; background: linear-gradient(135deg, #f8f9fa 0%, #e8eef2 40%, #dce8ed 70%, #f0f4f6 100%); }
	.bp-page .activities .section-header { text-align: center; max-width: 900px; margin: 0 auto 60px; }
	.bp-page .activities .section-header h2 { font-size: 42px; font-weight: 800; letter-spacing: -1px; line-height: 1.2; margin-bottom: 16px; }
	.bp-page .activities-slider { display: flex; gap: 24px; overflow-x: auto; padding-bottom: 24px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
	.bp-page .activities-slider::-webkit-scrollbar { height: 4px; }
	.bp-page .activities-slider::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); border-radius: 4px; }
	.bp-page .activities-slider::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 4px; }
	.bp-page .activities-slide { position: relative; border-radius: var(--radius); overflow: hidden; min-width: calc(33.333% - 16px); height: 380px; flex-shrink: 0; scroll-snap-align: start; }
	.bp-page .activities-slide img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s; }
	.bp-page .activities-slide:hover img { transform: scale(1.05); }
	@media (max-width: 768px) {
		.bp-page .activities-slider { display: none; }
		.bp-page .activities .section-header h2 { font-size: 28px; }
		.bp-page .activities .section-header { margin-bottom: 0; }
	}

	/* ── Features ── */
	.bp-page .features { padding: 100px 0; background: var(--primary-dark); color: var(--white); }
	.bp-page .features .section-header h2 { color: var(--white); }
	.bp-page .features .section-header p { color: rgba(255,255,255,0.7); }
	.bp-page .features .section-header { text-align: center; max-width: 900px; }
	.bp-page .features .section-header .hero-badge { margin-bottom: 24px; }
	.bp-page .features .section-header .hero-badge .dot { background: var(--cta); }
	.bp-page .features .section-header h2 { font-size: 72px; line-height: 1.1; margin-bottom: 24px; }
	.bp-page .features .section-header h2 .highlight { color: var(--accent); }
	.bp-page .features .section-header p { font-size: 20px; font-weight: 400; line-height: 1.6; letter-spacing: 0; }
	.bp-page .feature-list { display: flex; gap: 24px; overflow-x: auto; padding-bottom: 24px; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
	.bp-page .feature-list::-webkit-scrollbar { height: 4px; }
	.bp-page .feature-list::-webkit-scrollbar-track { background: rgba(255,255,255,0.1); border-radius: 4px; }
	.bp-page .feature-list::-webkit-scrollbar-thumb { background: var(--cta); border-radius: 4px; }
	.bp-page .feature-card { position: relative; border-radius: var(--radius); overflow: hidden; min-width: 320px; height: 460px; cursor: pointer; flex-shrink: 0; scroll-snap-align: start; }
	.bp-page .feature-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform .4s; }
	.bp-page .feature-card:hover .feature-card-bg { transform: scale(1.05); }
	.bp-page .feature-card-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.55) 100%); }
	.bp-page .feature-card-content { position: absolute; top: 0; left: 0; right: 0; padding: 28px; color: var(--white); }
	.bp-page .feature-card-content .service-label { font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 8px; opacity: 0.85; }
	.bp-page .feature-card-content h3 { font-size: 24px; font-weight: 700; }
	.bp-page .feature-nav { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }
	.bp-page .feature-nav-btn { width: 44px; height: 44px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.3); background: transparent; color: var(--white); font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s; }
	.bp-page .feature-nav-btn:hover { border-color: var(--white); background: rgba(255,255,255,0.1); }
	@media (max-width: 768px) {
		.bp-page .feature-card { min-width: 280px; height: 380px; }
		.bp-page .features .section-header h2 { font-size: 28px; }
		.bp-page .features .section-header p { font-size: 16px; }
	}

	/* ── Team ── */
	.bp-page .team { padding: 100px 0; background: linear-gradient(135deg, #f8f9fa 0%, #e8eef2 40%, #dce8ed 70%, #f0f4f6 100%); }
	.bp-page .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
	.bp-page .team-card { background: var(--white); border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); text-align: center; transition: transform .3s; position: relative; }
	.bp-page .team-card:hover { transform: translateY(-4px); box-shadow: var(--card-shadow); }
	.bp-page .team-card .team-photo { width: 100%; height: 300px; object-fit: cover; object-position: top; display: block; }
