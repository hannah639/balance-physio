---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import BookingCTA from '../components/BookingCTA.astro';
import Picture from '../components/Picture.astro';
import { testimonials } from '../data/testimonials.js';

// Any testimonial longer than this character count gets a "Read more" toggle.
const READ_MORE_THRESHOLD = 450;
---
<Layout
	title="Testimonials"
	description="Hear from our happy patients, real stories of recovery, performance and return to the things they love, from Balance Performance Physiotherapy in Clapham."
>
	<PageHero
		title="Testimonials"
		subtitle="Hear from our happy patients, real stories of recovery, resilience and return to performance."
		breadcrumb="Testimonials"
	/>

	<section class="testimonials-page">
		<div class="container">
			<div class="section-header">
				<h2>Kind words from our happy clients</h2>
			</div>
			<div class="testimonial-masonry">
				{testimonials.map((t) => {
					const isLong = t.quote.length > READ_MORE_THRESHOLD;
					const paras = t.quote.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
					return (
						<article class={`tm-card${isLong ? ' is-long' : ''}`}>
							<div class="tm-quote-mark">&ldquo;</div>
							<div class="tm-body">
								{paras.map((p) => <p>{p}</p>)}
							</div>
							{isLong && <button type="button" class="tm-toggle" aria-expanded="false">Read more</button>}
							<div class="tm-author">
								{t.image && (
									<div class="tm-avatar">
										<Picture src={t.image} alt={t.name} loading="lazy" decoding="async" width="120" height="120" />
									</div>
								)}
								<div class="tm-author-meta">
									<h4>{t.name}</h4>
									{t.role && <span>{t.role}</span>}
								</div>
							</div>
						</article>
					);
				})}
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>

<style>
	.testimonials-page {
		padding: 80px 0;
		background: #f4f6f7;
	}
	.testimonials-page .section-header {
		text-align: center;
		max-width: 700px;
		margin: 0 auto 56px;
	}
	.testimonials-page .section-header h2 {
		font-size: 42px;
		font-weight: 800;
		line-height: 1.2;
		margin-bottom: 16px;
		letter-spacing: -1px;
	}

	/* Masonry via CSS columns, lets cards size to content regardless of length */
	.testimonial-masonry {
		column-count: 3;
		column-gap: 28px;
	}
	.tm-card {
		display: flex;
		flex-direction: column;
		gap: 22px;
		break-inside: avoid;
		background: #ffffff;
		border: 1px solid #e5e9ec;
		border-radius: 15px;
		padding: 32px 28px 28px;
		margin: 0 0 28px;
		position: relative;
		transition: transform .25s, box-shadow .25s, border-color .25s;
	}
	.tm-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 30px rgba(0,0,0,0.06);
		border-color: #e87722;
	}
	.tm-quote-mark {
		position: absolute;
		top: 12px;
		right: 22px;
		font-family: Georgia, serif;
		font-size: 64px;
		line-height: 1;
		color: #e87722;
		opacity: 0.22;
		pointer-events: none;
	}
	.tm-body {
		font-size: 15px;
		line-height: 1.75;
		color: #3a4149;
		order: 2;
	}
	.tm-body p {
		margin: 0 0 14px;
	}
	.tm-body p:last-child { margin-bottom: 0; }

	/* Long testimonial truncation */
	.tm-card.is-long .tm-body {
		max-height: 320px;
		overflow: hidden;
		position: relative;
		mask-image: linear-gradient(to bottom, #000 75%, transparent 100%);
		-webkit-mask-image: linear-gradient(to bottom, #000 75%, transparent 100%);
	}
	.tm-card.is-long.is-expanded .tm-body {
		max-height: none;
		mask-image: none;
		-webkit-mask-image: none;
	}
	.tm-toggle {
		background: transparent;
		border: 0;
		padding: 0;
		margin: -4px 0 0;
		color: #3EBEDF;
		font-family: inherit;
		font-size: 14px;
		font-weight: 600;
		cursor: pointer;
		order: 3;
		align-self: flex-start;
	}
	.tm-toggle:hover { text-decoration: underline; }

	.tm-author {
		order: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		padding-bottom: 22px;
		border-bottom: 1px solid #eef1f3;
		text-align: center;
	}
	.tm-avatar {
		width: 170px;
		height: 170px;
		border-radius: 50%;
		overflow: hidden;
		flex-shrink: 0;
		background: #eef1f3;
		border: 4px solid #ffffff;
		box-shadow: 0 8px 24px rgba(0,0,0,0.10);
	}
	.tm-avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.tm-author-meta { min-width: 0; }
	.tm-author h4 {
		font-size: 17px;
		font-weight: 800;
		margin: 0;
		letter-spacing: -0.2px;
		color: #1a1a1a;
	}
	.tm-author span {
		display: block;
		margin-top: 4px;
		font-size: 12px;
		color: #7a828a;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	@media (max-width: 1100px) {
		.testimonial-masonry { column-count: 2; }
	}
	@media (max-width: 700px) {
		.testimonials-page { padding: 56px 0; }
		.testimonial-masonry { column-count: 1; }
		.testimonials-page .section-header h2 { font-size: 32px; }
	}
</style>

<script is:inline>
	(function () {
		document.querySelectorAll('.tm-toggle').forEach(function (btn) {
			btn.addEventListener('click', function () {
				var card = btn.closest('.tm-card');
				if (!card) return;
				var expanded = card.classList.toggle('is-expanded');
				btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
				btn.textContent = expanded ? 'Read less' : 'Read more';
			});
		});
	})();
</script>
