---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import BookingCTA from '../components/BookingCTA.astro';

const testimonials = [
	{ quote: "The knee seems stable and the arching exercises for the foot have helped loads!", name: "Jamie N" },
	{ quote: "They say you sometimes come back from injury stronger, and I want to thank you", name: "Sharon Templeman" },
	{ quote: "I don't quite know where I would be right now without all your help", name: "Tal H" },
	{ quote: "If you exercise, go visit these guys as they're completely brilliant", name: "Owen Carmen" },
	{ quote: "I can't thank you enough for your incredibly helpful intervention.", name: "Sheila W" },
	{ quote: "Balance has educated me in how to stay fit and protect against injury", name: "Ian Brown" },
	{ quote: "Thanks to Caroline and the brilliant team at Balance for helping me rehab", name: "Shafik S" },
	{ quote: "Balance is a great asset and an excellent team to work with", name: "Winston Gordon", role: "Team GB Judo Triple Olympian" },
	{ quote: "@BalancePrfmance really pleased with the taping it helped a lot!", name: "Simon Buckden" },
	{ quote: "The Balance team gave us valuable advice and preparation for our cycle", name: "Matt & Andy", role: "The Cycle Diaries" },
	{ quote: "I've worked with the Balance Team for the last 6 years now", name: "Leoni Munslow" },
	{ quote: "The superb technical knowledge of physiotherapy is a given at Balance", name: "Louise Ward", role: "Round the World Yachtswomen" },
	{ quote: "They are passionate about what they do, utterly professional", name: "Claire Bennett", role: "Team GB Fencer" },
	{ quote: "I found them extremely effective for pain relief and muscle strength", name: "Amanda H." },
	{ quote: "I have found Balance Performance Physiotherapy to be an inspiration!", name: "Miriam Bremer", role: "Pilates teacher" },
	{ quote: "I'm absolutely over the moon to have just run a marathon PB", name: "Al Riley" },
	{ quote: "The pain went away following your advice and exercises", name: "Kate Hudson" },
	{ quote: "My son has actively enjoyed going to see Dan Elias for physio", name: "Samantha O." },
	{ quote: "Thank you Caroline and Balance Physio so much for guiding my journey", name: "George C" },
	{ quote: "I felt a million times better going into the race after seeing them", name: "Bryony M." },
	{ quote: "I cannot recommend Balance highly enough", name: "Tom Holland", role: "Amateur cricket" },
	{ quote: "I am happy to report I am back to being fully functional", name: "Patient G" },
	{ quote: "Their ability and determination to get one back playing is great", name: "John Hunt" },
];
---
<Layout
	title="Testimonials"
	description="Hear from our happy patients — real stories of recovery, performance and return to the things they love, from Balance Performance Physiotherapy in Clapham."
>
	<PageHero
		title="Testimonials"
		subtitle="Hear from our happy patients — real stories of recovery, resilience and return to performance."
		breadcrumb="Testimonials"
	/>

	<section class="testimonials">
		<div class="container">
			<div class="section-header">
				<h2>Kind words from our happy clients</h2>
			</div>
			<div class="testimonial-grid">
				{testimonials.map((t) => (
					<div class="testimonial-card">
						<p>{t.quote}</p>
						<div class="testimonial-author">
							<div>
								<h4>{t.name}</h4>
								{t.role && <span>{t.role}</span>}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>
