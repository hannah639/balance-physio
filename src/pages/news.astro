---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import BookingCTA from '../components/BookingCTA.astro';
import Picture from '../components/Picture.astro';
import { news } from '../data/news.js';
import { team, initials, gradientFor } from '../data/team.js';

// Look up team members by slug so news items can reference clinicians.
const teamBySlug = Object.fromEntries(team.map((m) => [m.slug, m]));

// Short professional bio for the profile summary: first 1–2 sentences of the
// member's bio, capped at ~240 characters, taken from their bio page content.
function shortBio(member) {
	if (!member || !member.bio || !member.bio.length) return '';
	const first = member.bio[0];
	const sentences = first.match(/[^.!?]+[.!?]+/g) || [first];
	let out = '';
	for (const s of sentences) {
		if (out && (out + s).length > 240) break;
		out += s;
	}
	out = out.trim();
	return out || first.slice(0, 220).trim() + '…';
}

// Resolve each item's clinician slugs to team members (skip any unknown slug).
function cliniciansFor(item) {
	if (!item.clinicians) return [];
	return item.clinicians.map((slug) => teamBySlug[slug]).filter(Boolean);
}
---
<Layout
	title="What have we been up to? | News & Events"
	description="News & Events from Balance Performance Physiotherapy in Clapham."
>
	<PageHero
		title="What have we been up to?"
		breadcrumb="What have we been up to?"
	/>

	<section class="news-page">
		<div class="container">
			{news.length === 0 ? (
				<p class="news-empty">More news coming soon — watch this space.</p>
			) : (
				<div class="news-list">
					{news.map((item, i) => {
						const clinicians = cliniciansFor(item);
						const bottom = item.imageLayout === 'bottom';
						return (
						<article class={`news-card${bottom ? ' news-card--bottom' : (i % 2 === 1 ? ' news-card--reverse' : '')}`} id={item.slug}>
							{item.image && !bottom && (
								<div class={`news-photo${item.imageFit === 'contain' ? ' news-photo--contain' : ''}`} style={item.imagePosition ? `--news-photo-position: ${item.imagePosition};` : undefined}>
									<Picture src={item.image} alt={item.imageAlt || ''} loading="lazy" decoding="async" width="800" height="600" />
								</div>
							)}
							<div class="news-body">
								{(item.category || item.date) && (
									<div class="news-meta">
										{item.category && <span class="news-category">{item.category}</span>}
										{item.date && <time class="news-date">{item.date}</time>}
									</div>
								)}
								<h2>{item.headline}</h2>
								{item.allowHtml
									? item.body.map((p) => <p set:html={p}></p>)
									: item.body.map((p) => <p>{p}</p>)}
								{clinicians.length > 0 && (
									<div class="news-clinicians">
										{clinicians.map((c) => (
											<div class="news-clinician">
												{c.photo ? (
													<div class="nc-avatar">
														<Picture src={c.photo} alt={c.name} loading="lazy" decoding="async" width="120" height="120" />
													</div>
												) : (
													<div class="nc-avatar nc-avatar--initials" style={`background: ${gradientFor(c.name)};`}>
														<span>{initials(c.name)}</span>
													</div>
												)}
												<div class="nc-meta">
													<p class="nc-name">{c.name}</p>
													<p class="nc-bio">{shortBio(c)}</p>
													<a class="nc-link" href={`/team/${c.slug}/`}>Read Full Bio &rarr;</a>
												</div>
											</div>
										))}
									</div>
								)}
								{item.cta && (
									item.cta.external
										? <a class="news-cta-btn" href={item.cta.href} target="_blank" rel="noopener">{item.cta.label}</a>
										: <a class="news-cta-btn" href={item.cta.href}>{item.cta.label}</a>
								)}
							</div>
							{item.image && bottom && (
								<div class={`news-photo news-photo--bottom${item.imageFit === 'contain' ? ' news-photo--contain' : ''}`}>
									<Picture src={item.image} alt={item.imageAlt || ''} loading="lazy" decoding="async" width="1400" height="1050" />
								</div>
							)}
						</article>
						);
					})}
				</div>
			)}
		</div>
	</section>

	<BookingCTA />
</Layout>

<style>
	.news-page { padding: 80px 0; background: linear-gradient(135deg, #f8f9fa 0%, #e8eef2 40%, #dce8ed 70%, #f0f4f6 100%); }
	.news-page .container { max-width: 1100px; }
	.news-empty { text-align: center; font-size: 18px; color: #555; padding: 60px 0; }

	.news-list { display: flex; flex-direction: column; gap: 56px; }
	.news-card {
		background: #ffffff;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 16px 48px rgba(0,0,0,0.08);
		display: grid;
		grid-template-columns: 5fr 7fr;
		align-items: stretch;
	}
	.news-card--reverse { grid-template-columns: 7fr 5fr; }
	.news-card--reverse .news-photo { order: 2; }
	.news-card--reverse .news-body { order: 1; }

	/* Bottom layout: body on top, landscape photo running full-width along the
	   bottom of the card (used where a side image would crop badly). */
	.news-card--bottom { display: flex; flex-direction: column; }
	.news-card--bottom .news-photo--bottom {
		width: 100%;
		min-height: 0;
		aspect-ratio: 16 / 9;
	}

	.news-photo {
		position: relative;
		min-height: 360px;
		background: #f0f4f6;
		overflow: hidden;
	}
	.news-photo img {
		position: absolute; inset: 0;
		width: 100%; height: 100%;
		object-fit: cover;
		object-position: var(--news-photo-position, center top);
		display: block;
	}
	/* Whole-image display for text-heavy graphics (e.g. event posters) that
	   must not be cropped. Letterboxes against a dark backdrop that blends
	   with the poster's own background. */
	.news-photo--contain { background: #0d2438; }
	.news-photo--contain img { object-fit: contain; object-position: center; }

	.news-body { padding: 48px; display: flex; flex-direction: column; justify-content: center; }
	.news-meta { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; flex-wrap: wrap; }
	.news-category {
		display: inline-block;
		background: rgba(232,119,34,0.1);
		color: #e87722;
		font-size: 12px; font-weight: 700;
		text-transform: uppercase; letter-spacing: 1.5px;
		padding: 5px 12px;
		border-radius: 50px;
	}
	.news-date { font-size: 13px; color: #777; font-weight: 500; }
	.news-body h2 {
		font-size: 30px; font-weight: 800; line-height: 1.2;
		letter-spacing: -0.5px; margin: 0 0 20px; color: #1a1a1a;
	}
	.news-body p {
		font-size: 16px; line-height: 1.75; color: #555;
		margin: 0 0 16px;
	}
	.news-body p:last-child { margin-bottom: 0; }
	.news-body a:not(.news-cta-btn):not(.nc-link) { color: #3EBEDF; font-weight: 600; }
	.news-body a:not(.news-cta-btn):not(.nc-link):hover { text-decoration: underline; }

	/* Clinician profile summary(ies), shown beneath the event content.
	   Webflow-style mini profile cards: a clean rounded portrait (15px radius,
	   cover, top-anchored), a soft surface, generous spacing and a refined
	   arrow link — designed to feel modern and consistent with the site. */
	.news-clinicians {
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin-top: 28px;
		padding-top: 28px;
		border-top: 1px solid #eef1f3;
	}
	.news-clinician {
		display: flex;
		gap: 20px;
		align-items: center;
		background: #f7f9fa;
		border: 1px solid #edf1f3;
		border-radius: 15px;
		padding: 18px 20px;
		transition: box-shadow .2s ease, transform .2s ease;
	}
	.news-clinician:hover { box-shadow: 0 12px 30px rgba(0,0,0,0.07); transform: translateY(-2px); }
	.nc-avatar {
		flex: 0 0 104px;
		width: 104px; height: 130px;
		border-radius: 15px;
		overflow: hidden;
		background: #eef1f3;
		box-shadow: 0 8px 22px rgba(0,0,0,0.12);
	}
	.nc-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
	.nc-avatar--initials { display: flex; align-items: center; justify-content: center; }
	.nc-avatar--initials span { color: #fff; font-size: 34px; font-weight: 800; letter-spacing: -1px; }
	.nc-meta { min-width: 0; }
	.nc-name { font-size: 18px; font-weight: 800; color: #1a1a1a; margin: 0 0 6px; letter-spacing: -0.3px; }
	.nc-bio { font-size: 14.5px; line-height: 1.6; color: #5a626a; margin: 0 0 10px; }
	.nc-link {
		display: inline-flex; align-items: center; gap: 5px;
		font-size: 14px; font-weight: 700; color: #3EBEDF;
		text-decoration: none;
		transition: color .15s ease, gap .15s ease;
	}
	.nc-link:hover { color: #2898b5; gap: 9px; }

	@media (max-width: 480px) {
		.news-clinician { gap: 16px; padding: 16px; }
		.nc-avatar { flex-basis: 88px; width: 88px; height: 112px; }
	}

	/* Prominent CTA button (sponsorship / booking) after the event body */
	.news-cta-btn {
		display: inline-block;
		align-self: flex-start;
		margin-top: 20px;
		padding: 13px 28px;
		background: #e87722;
		color: #ffffff;
		font-size: 15px; font-weight: 700;
		border-radius: 50px;
		text-decoration: none;
		transition: background .2s ease, transform .15s ease;
	}
	.news-cta-btn:hover { background: #d06618; transform: translateY(-2px); }

	@media (max-width: 900px) {
		.news-page { padding: 60px 0; }
		.news-list { gap: 40px; }
		.news-card,
		.news-card--reverse { grid-template-columns: 1fr; }
		.news-card--reverse .news-photo { order: 0; }
		.news-card--reverse .news-body { order: 1; }
		.news-photo { min-height: 0; aspect-ratio: 4/3; }
		.news-body { padding: 32px 24px; }
		.news-body h2 { font-size: 24px; }
		.news-body p { font-size: 15px; }
	}
</style>
