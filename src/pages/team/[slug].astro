---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import { team, initials, gradientFor } from '../../data/team.js';

export function getStaticPaths() {
	return team.map((member) => ({
		params: { slug: member.slug },
		props: { member },
	}));
}

const { member } = Astro.props;
const avatarGradient = gradientFor(member.name);
---
<Layout
	title={member.name}
	description={`${member.name}, ${member.role} at Balance Performance Physiotherapy in Clapham.`}
>
	<PageHero
		title={member.role}
		highlight={member.name}
		breadcrumb={member.name}
	/>

	<section class="bio-section">
		<div class="container">
			<div class="bio-grid">
				{member.photo ? (
					<div class="bio-photo bio-photo--img">
						<img src={member.photo} alt={member.name} />
					</div>
				) : (
					<div class="bio-photo" style={`background: ${avatarGradient};`}>
						<span class="bio-initials">{initials(member.name)}</span>
					</div>
				)}
				<div class="bio-body">
					<div class="eyebrow"><span class="eyebrow-dot"></span>About {member.name.split(' ')[0]}</div>
					<h2>{member.name}</h2>
					<p class="bio-role">{member.role}</p>
					{member.bio ? (
						member.bio.map((p) => <p>{p}</p>)
					) : (
						<>
							<p>{member.name} is part of the Balance Performance Physiotherapy team in Clapham. A full bio is coming soon, in the meantime, you can book a session directly or call our reception team for more information.</p>
							<p>Our clinicians work collaboratively across specialisms, so if you're not sure who to book with, our admin team will match you with the right practitioner for your needs.</p>
						</>
					)}
					<p><a href="/meet-the-team" class="inline-link">&laquo; Back to the team</a></p>
				</div>
			</div>
		</div>
	</section>

	<BookingCTA />
</Layout>

<style>
	.bio-section { padding: 80px 0; background: #ffffff; }
	.bio-grid { display: grid; grid-template-columns: 320px 1fr; gap: 64px; align-items: start; max-width: 1000px; margin: 0 auto; }
	.bio-photo { width: 320px; height: 400px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 20px 60px rgba(0,0,0,0.12); overflow: hidden; }
	.bio-photo--img { padding: 0; }
	.bio-photo--img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}
	.bio-initials { color: #ffffff; font-size: 96px; font-weight: 800; letter-spacing: -3px; font-family: 'Inter', sans-serif; }
	.bio-body .eyebrow { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,0,0,0.06); border: 1px solid rgba(0,0,0,0.1); border-radius: 50px; padding: 6px 16px; font-size: 13px; font-weight: 600; color: #1a1a1a; margin-bottom: 20px; }
	.bio-body .eyebrow-dot { width: 8px; height: 8px; border-radius: 50%; background: #e87722; }
	.bio-body h2 { font-size: 36px; font-weight: 800; letter-spacing: -1px; line-height: 1.15; margin-bottom: 8px; }
	.bio-role { font-size: 14px; color: #e87722; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 24px; }
	.bio-body p { font-size: 17px; line-height: 1.8; color: #555555; margin-bottom: 18px; }
	.bio-body .inline-link { color: #3EBEDF; font-weight: 600; }
	.bio-body .inline-link:hover { text-decoration: underline; }
	@media (max-width: 900px) {
		.bio-section { padding: 60px 0; }
		.bio-grid { grid-template-columns: 1fr; gap: 32px; }
		/* On mobile, keep the photo's natural 3:4 portrait ratio so faces
		   aren't cropped off at the top or bottom by the desktop fixed
		   height of 280px. */
		.bio-photo { width: 100%; max-width: 320px; height: auto; aspect-ratio: 3/4; margin: 0 auto; }
		.bio-initials { font-size: 72px; }
		.bio-body h2 { font-size: 28px; }
	}
</style>
