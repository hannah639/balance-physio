---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ImageText from '../components/ImageText.astro';
import BookingCTA from '../components/BookingCTA.astro';
---
<Layout
	title="Contact Us"
	description="Get in touch with Balance Performance Physiotherapy in Clapham. Call 020 7627 2308 or email enquiries@balancephysio.com."
>
	<PageHero
		title="In Touch"
		highlight="Get"
		subtitle="Questions? Want to book? Happy to help — we'll get back to you as soon as we can."
		breadcrumb="Contact Us"
	/>

	<ImageText
		eyebrow="Say hello"
		heading="How to"
		highlight="reach us"
		placeholderLabel="Reception desk"
	>
		<ul>
			<li><strong>Phone:</strong> <a href="tel:02076272308" class="inline-link">020 7627 2308</a></li>
			<li><strong>Email:</strong> <a href="mailto:enquiries@balancephysio.com" class="inline-link">enquiries@balancephysio.com</a></li>
			<li><strong>Address:</strong> 113 Gauden Rd, London SW4 6LE, United Kingdom</li>
		</ul>
		<p>For new patients, our admin team will send you a quick registration form by email. Once that's back with us, we'll book you in with the right clinician.</p>
	</ImageText>

	<ImageText
		eyebrow="Opening hours"
		heading="When we're"
		highlight="open"
		reverse
		altBg
		placeholderLabel="Clinic hours"
	>
		<ul>
			<li>Monday, Tuesday, Wednesday — 7:30am to 8:00pm</li>
			<li>Thursday — 8:00am to 7:00pm</li>
			<li>Friday — 7:30am to 6:00pm</li>
			<li>Saturday — 8:00am to 4:00pm</li>
			<li>Sunday — Studio hire events only</li>
		</ul>
	</ImageText>

	<BookingCTA />
</Layout>
