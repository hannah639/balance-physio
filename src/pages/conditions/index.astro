---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import BookingCTA from '../../components/BookingCTA.astro';

const groups = [
	{
		title: 'Back, Neck & Spine',
		items: [
			{ title: 'Lower Back Pain', href: '/condition/lower-back-pain' },
			{ title: 'Neck Pain', href: '/condition/neck-pain' },
		],
	},
	{
		title: 'Joints',
		items: [
			{ title: 'Shoulder Pain', href: '/condition/shoulder-pain' },
			{ title: 'Elbow Pain', href: '/condition/elbow-pain' },
			{ title: 'Hip Pain', href: '/condition/hip-pain' },
			{ title: 'Knee Injuries', href: '/condition/knee-injuries' },
		],
	},
	{
		title: 'Foot & Ankle',
		items: [
			{ title: 'Foot Pain', href: '/condition/foot-pain' },
			{ title: 'Ankle Pain', href: '/condition/ankle-pain' },
			{ title: 'Verrucas', href: '/condition/verrucas' },
			{ title: 'Ingrown Toenails', href: '/condition/ingrown-toenails' },
		],
	},
	{
		title: 'Sports Injuries',
		items: [
			{ title: 'Cycling Injuries', href: '/condition/cycling-injuries' },
			{ title: 'Running Injuries', href: '/condition/running-injuries' },
		],
	},
	{
		title: 'Pelvic Health',
		items: [
			{ title: "Women's Pelvic Health", href: '/condition/womens-pelvic-health' },
			{ title: "Men's Pelvic Health", href: '/condition/mens-pelvic-health' },
		],
	},
	{
		title: 'Neurological',
		items: [
			{ title: 'Multiple Sclerosis', href: '/condition/multiple-sclerosis' },
			{ title: 'Stroke', href: '/condition/stroke' },
			{ title: "Parkinson's", href: '/condition/parkinsons' },
			{ title: 'Balance & Dizziness', href: '/condition/balance-and-dizziness' },
			{ title: "Children's Neurological & Developmental", href: '/condition/childrens-neurological-developmental' },
		],
	},
];
---
<Layout
	title="Conditions We Treat"
	description="From back pain to neurological conditions, explore every area we treat at Balance Performance Physiotherapy in Clapham, London."
>
	<PageHero
		title="We Treat"
		highlight="Conditions"
		subtitle="From everyday aches to complex neurological conditions, expert care across every area."
		breadcrumb="Conditions"
	/>

	<section class="link-grid-section">
		<div class="container">
			{groups.map((group) => (
				<div style="margin-bottom: 48px;">
					<h2 style="font-size: 24px; font-weight: 800; margin-bottom: 20px; letter-spacing: -0.5px;">{group.title}</h2>
					<div class="link-grid">
						{group.items.map((item) => (
							<a href={item.href} class="link-grid-item">
								<h3>{item.title}</h3>
								<span class="arrow">Learn more &rsaquo;</span>
							</a>
						))}
					</div>
				</div>
			))}
		</div>
	</section>

	<BookingCTA />
</Layout>
