---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import ImageText from '../../components/ImageText.astro';
import BookingCTA from '../../components/BookingCTA.astro';
---
<Layout
	title="Clapham Clinic"
	description="Visit Balance Performance Physiotherapy at 113 Gauden Rd, London SW4 6LE — London's largest rehabilitation centre in the heart of Clapham."
>
	<PageHero
		title="Clinic"
		highlight="Clapham"
		subtitle="113 Gauden Rd, London SW4 6LE — London's largest rehabilitation centre, a short walk from Clapham High Street."
		breadcrumb="Clapham Clinic"
	/>

	<section class="clapham-intro">
		<div class="clapham-intro-inner">
			<div class="clapham-intro-copy">
				<div class="eyebrow"><span class="eyebrow-dot"></span>Location</div>
				<h2>Right in the heart of <span class="highlight">Clapham</span></h2>
				<p>You'll find us at <strong>113 Gauden Rd, London SW4 6LE</strong> — a short walk from Clapham Common, Clapham North and Clapham High Street.</p>
				<ul class="check-list">
					<li>Closest Tube: Clapham North (Northern line)</li>
					<li>Closest Rail: Clapham High Street (Overground)</li>
					<li>Buses: 50, 88, 155, 322, 345</li>
					<li>Bike rack at reception</li>
					<li>Wheelchair ramp at the front door (buzzer controlled)</li>
				</ul>
			</div>

			<form class="clapham-form" action="https://formsubmit.co/enquiries@balancephysio.com" method="POST">
				<div class="eyebrow eyebrow-orange">Send us a message</div>

				<!-- Formsubmit.co config — no signup needed; first submission triggers an activation email to enquiries@balancephysio.com -->
				<input type="hidden" name="_subject" value="New enquiry from Balance Physio website" />
				<input type="hidden" name="_template" value="table" />
				<input type="hidden" name="_captcha" value="true" />
				<input type="hidden" name="_next" value="https://balance-physio.hannah-9e0.workers.dev/clinic/clapham/?sent=1" />

				<div class="form-row">
					<input type="text" name="First Name" placeholder="First Name" required aria-label="First Name" />
					<input type="text" name="Last Name" placeholder="Last Name" required aria-label="Last Name" />
				</div>
				<div class="form-row">
					<input type="tel" name="Phone Number" placeholder="Phone Number" aria-label="Phone Number" />
					<input type="email" name="Email Address" placeholder="Email Address" required aria-label="Email Address" />
				</div>
				<textarea name="Message" placeholder="Write your message here" rows="5" required aria-label="Message"></textarea>
				<button type="submit" class="form-submit">Send Message</button>
				<p class="form-note">We'll reply within one working day.</p>
			</form>
		</div>
	</section>

	<ImageText
		eyebrow="Opening hours"
		heading="Open from early"
		highlight="until late"
		reverse
		altBg
		placeholderLabel="Reception open sign"
	>
		<ul>
			<li>Monday, Tuesday, Wednesday — 7:30am to 8:00pm</li>
			<li>Thursday — 8:00am to 7:00pm</li>
			<li>Friday — 7:30am to 6:00pm</li>
			<li>Saturday — 8:00am to 4:00pm</li>
			<li>Sunday — Studio hire events only</li>
		</ul>
		<p>Book online, call us on <strong>020 7627 2308</strong> or email <a href="mailto:enquiries@balancephysio.com" class="inline-link">enquiries@balancephysio.com</a>.</p>
	</ImageText>

	<ImageText
		eyebrow="What's here"
		heading="Everything under"
		highlight="one roof"
		placeholderLabel="Facilities overview"
	>
		<ul>
			<li>9 treatment rooms (4 downstairs, 5 on the first floor)</li>
			<li>Dedicated medical room for ultrasound &amp; injections</li>
			<li>Class &amp; Movement Studio for end-stage rehab and training</li>
			<li>Early Rehab Studio connected to four treatment rooms</li>
			<li>Reception shop for protection, recovery &amp; performance</li>
			<li>WorkSpace showroom for ergonomic products</li>
			<li>Free Wi-Fi and comfortable waiting area</li>
		</ul>
	</ImageText>

	<BookingCTA />
</Layout>

<style>
	.clapham-intro { padding: 90px 24px; background: #ffffff; }
	.clapham-intro-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 64px;
		align-items: start;
	}
	.clapham-intro-copy .eyebrow {
		display: inline-flex; align-items: center; gap: 8px;
		background: rgba(0,0,0,0.06);
		border: 1px solid rgba(0,0,0,0.1);
		border-radius: 50px;
		padding: 6px 16px;
		font-size: 13px; font-weight: 600; color: #1a1a1a;
		margin-bottom: 20px;
	}
	.clapham-intro-copy .eyebrow-dot {
		width: 8px; height: 8px; border-radius: 50%; background: #e87722;
	}
	.clapham-intro-copy h2 {
		font-size: 40px; font-weight: 800; line-height: 1.15;
		letter-spacing: -1px; margin: 0 0 20px; color: #1a1a1a;
	}
	.clapham-intro-copy h2 .highlight { color: #e87722; }
	.clapham-intro-copy p {
		font-size: 17px; line-height: 1.8; color: #555555;
		margin: 0 0 20px;
	}
	.clapham-intro-copy .check-list { list-style: none; margin: 20px 0; padding: 0; }
	.clapham-intro-copy .check-list li {
		position: relative; padding: 8px 0 8px 32px;
		font-size: 16px; color: #555555; line-height: 1.6;
	}
	.clapham-intro-copy .check-list li::before {
		content: ''; position: absolute; left: 0; top: 15px;
		width: 18px; height: 18px; border-radius: 50%; background: #e87722;
	}
	.clapham-intro-copy .check-list li::after {
		content: '✓'; position: absolute; left: 4px; top: 10px;
		color: #ffffff; font-size: 11px; font-weight: 800;
	}

	/* Contact form */
	.clapham-form {
		background: #f4f6f7;
		border: 1px solid #e5e9ec;
		border-radius: 20px;
		padding: 36px 32px;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}
	.eyebrow-orange {
		display: inline-block;
		font-size: 12px;
		font-weight: 700;
		color: #e87722;
		text-transform: uppercase;
		letter-spacing: 3px;
		margin-bottom: 8px;
	}
	.clapham-form .form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px;
	}
	.clapham-form input[type="text"],
	.clapham-form input[type="tel"],
	.clapham-form input[type="email"],
	.clapham-form textarea {
		width: 100%;
		padding: 14px 18px;
		border: 1px solid #d8dee2;
		border-radius: 50px;
		font-family: inherit;
		font-size: 15px;
		background: #ffffff;
		color: #1a1a1a;
		transition: border-color .2s, box-shadow .2s;
	}
	.clapham-form textarea {
		border-radius: 18px;
		resize: vertical;
		min-height: 120px;
	}
	.clapham-form input::placeholder,
	.clapham-form textarea::placeholder {
		color: #9aa1a6;
	}
	.clapham-form input:focus,
	.clapham-form textarea:focus {
		outline: none;
		border-color: #3EBEDF;
		box-shadow: 0 0 0 3px rgba(62,190,223,0.15);
	}
	.clapham-form .form-submit {
		margin-top: 6px;
		padding: 16px 28px;
		border: 0;
		border-radius: 50px;
		background: #3EBEDF;
		color: #ffffff;
		font-family: inherit;
		font-size: 16px;
		font-weight: 700;
		cursor: pointer;
		transition: background .2s, transform .2s;
	}
	.clapham-form .form-submit:hover {
		background: #32a8c6;
		transform: translateY(-1px);
	}
	.clapham-form .form-note {
		margin: 4px 0 0;
		font-size: 12px;
		color: #7a828a;
		text-align: center;
	}
	@media (max-width: 900px) {
		.clapham-intro { padding: 60px 20px; }
		.clapham-intro-inner { grid-template-columns: 1fr; gap: 40px; }
		.clapham-intro-copy h2 { font-size: 32px; }
		.clapham-form { padding: 28px 22px; }
		.clapham-form .form-row { grid-template-columns: 1fr; gap: 10px; }
	}
</style>
