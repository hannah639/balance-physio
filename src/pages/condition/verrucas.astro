---
import ConditionPage from '../../components/ConditionPage.astro';
---
<ConditionPage
	title="Treatment in Clapham"
	highlight="Verrucas"
	heroSubtitle="Verrucas can be painful and persistent — but with the right care, they can be cleared and kept away."
	breadcrumb="Verrucas"
	seoTitle="Verruca Treatment in Clapham"
	seoDescription="Expert verruca treatment in Clapham. We take a straightforward, clinical approach focused on clearing the virus, reducing pain and protecting the area from spread."
	introImage="/condition/verrucas/feet-on-sand.jpg"
	whoImage="/condition/verrucas/childrens-feet.jpg"
	intro={[
		"We take a straightforward, clinical approach focused on getting results. Our chiropody team will confirm the diagnosis, remove the hard skin protecting the verruca and apply the right treatment to help your body clear the virus.",
	]}
	symptomsHeading="When to get your verruca"
	symptomsHighlight="checked"
	symptomsList={[
		"Pain when walking or standing, especially on hard surfaces",
		"Small black dots within the lesion",
		"A rough area of skin that interrupts normal skin lines",
		"Pain when squeezing the sides of the area",
		"Verrucas that are spreading or forming clusters",
		"A verruca that isn't improving with home treatment",
	]}
	treatmentHeading="How we treat"
	treatmentHighlight="verrucas"
	treatmentIntro="Treatment may include:"
	treatmentList={[
		"Chiropody assessment to confirm diagnosis",
		"Removal of hard skin to expose the verruca",
		"Targeted treatment to help the body clear the virus",
		"Advice on reducing spread and protecting the area",
		"Ongoing care if multiple sessions are needed",
	]}
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Active individuals and runners with painful verrucas",
		"Children and teenagers with infections from pools or changing rooms",
		"People who have tried home treatments without success",
		"Those on their feet all day who need reliable solutions",
	]}
	faqs={[
		{ q: "Is a verruca the same as a corn?", a: "No. Verrucas are caused by a virus, while corns are pressure-related." },
		{ q: "Is treatment painful?", a: "Most treatments are well tolerated. We aim to keep you as comfortable as possible throughout." },
		{ q: "How many sessions will I need?", a: "It depends on the size and how long it's been there. Some verrucas need a few treatments to fully resolve." },
		{ q: "Are verrucas contagious?", a: "Yes — they can spread through direct contact or shared surfaces like changing rooms." },
		{ q: "Can I still exercise or swim?", a: "Usually, yes. We'll advise you on how to protect the area during activity." },
	]}
/>
