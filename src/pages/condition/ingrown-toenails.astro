---
import ConditionPage from '../../components/ConditionPage.astro';
---
<ConditionPage
	title="Treatment in Clapham"
	highlight="Ingrown Toenails"
	heroSubtitle="Ingrown toenails are common — but they can quickly become painful and difficult to manage on your own."
	breadcrumb="Ingrown Toenails"
	seoTitle="Ingrown Toenail Treatment in Clapham"
	seoDescription="Expert ingrown toenail treatment in Clapham. We focus on the root cause — not just the symptoms — to restore comfort and help prevent the problem coming back."
	intro={[
		"We focus on addressing the root cause rather than just easing the symptoms. Whether it's a one-off or a recurring issue, our goal is to restore comfort and help prevent it coming back.",
	]}
	symptomsHeading="When to get your toenail"
	symptomsHighlight="checked"
	symptomsList={[
		"Pain or tenderness along the edge of the nail",
		"Redness or swelling around the toe",
		"Difficulty wearing shoes comfortably",
		"Discharge, bleeding or signs of infection",
		"Overgrowth of tissue around the nail",
		"Ongoing or recurring ingrown toenails",
	]}
	treatmentHeading="How we treat"
	treatmentHighlight="ingrown toenails"
	treatmentIntro="Treatment may include:"
	treatmentList={[
		"Chiropody assessment to identify the underlying cause",
		"Careful removal of the ingrown nail section",
		"Treatment of any inflammation or infection",
		"Nail care and footwear guidance",
		"Minor nail surgery for persistent cases",
	]}
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Runners and active individuals with pressure on the toes",
		"Teenagers dealing with recurring nail problems",
		"People struggling to manage nails safely at home",
		"Those with persistent or infected ingrown toenails",
	]}
	faqs={[
		{ q: "Can I cut it out myself?", a: "We don't recommend it. It often makes the problem worse and increases the risk of infection." },
		{ q: "Will treatment hurt?", a: "Most treatments are well tolerated. If a procedure is needed, we can fully numb the toe to keep you comfortable." },
		{ q: "Will it come back?", a: "With the right treatment and advice, recurrence can usually be prevented." },
		{ q: "How long is recovery after nail surgery?", a: "Most people are back to normal activities within a few days, with some short-term adjustments." },
		{ q: "Do I need antibiotics?", a: "Not always. Treating the nail itself is usually the most important step in resolving the problem." },
	]}
/>
