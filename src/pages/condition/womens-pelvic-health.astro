---
import ConditionPage from '../../components/ConditionPage.astro';
---
<ConditionPage
	title="Treatment in Clapham"
	highlight="Women's Pelvic Health"
	heroSubtitle="Pelvic health issues are common, but they're often not talked about. Get expert, confidential support from a team you can trust."
	breadcrumb="Women's Pelvic Health"
	seoTitle="Women's Pelvic Health Treatment in Clapham"
	seoDescription="Expert women's pelvic health physiotherapy in Clapham, London. Supportive, confidential care for pelvic floor, bladder, bowel and pregnancy-related issues."
	introImage="/condition/womens-pelvic-health/women-group.jpg"
	whoImage="/condition/womens-pelvic-health/pregnant-belly.jpg"
	intro={[
		"Pelvic health issues are common, but they're often not talked about. We provide a supportive and confidential environment to help you understand and improve your condition, whether your symptoms are recent or long-standing.",
		"Whatever you're experiencing, our team is here to listen, assess and help you get back to feeling like yourself again.",
	]}
	symptomsHeading="When to get it"
	symptomsHighlight="checked"
	symptomsIntro="You might benefit from treatment if you're experiencing any of the following:"
	symptomsList={[
		"Leaking when you cough, sneeze, exercise, or laugh",
		"A sudden urgency to go to the toilet",
		"A feeling of heaviness or dragging in the pelvic area",
		"Ongoing pelvic or lower abdominal pain",
		"Pain during or after sex",
		"Difficulty controlling wind or bowel movements",
		"Pregnancy-related issues such as pelvic pain or abdominal separation",
	]}
