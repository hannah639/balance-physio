---
import ConditionPage from '../../components/ConditionPage.astro';
---
<ConditionPage
	title="Treatment in Clapham"
	highlight="Men's Pelvic Health"
	heroSubtitle="Pelvic health issues in men are more common than many people realise, but they're often not talked about. Get confidential, expert support."
	breadcrumb="Men's Pelvic Health"
	seoTitle="Men's Pelvic Health Treatment in Clapham"
	seoDescription="Expert men's pelvic health physiotherapy in Clapham, London. Confidential assessment and treatment for pelvic pain, bladder, bowel and post-surgery issues."
	introImage="/condition/mens-pelvic-health/man-relaxed.jpg"
	whoImage="/condition/mens-pelvic-health/man-hiking.jpg"
	intro={[
		"Pelvic health issues in men are more common than many people realise, but they're often not talked about. We offer a confidential and supportive space to help you understand your symptoms and improve them, whether they're new or long-standing.",
		"From post-prostate surgery recovery to ongoing pelvic pain, we'll build a plan around what you need.",
	]}
	symptomsHeading="When to get it"
	symptomsHighlight="checked"
	symptomsIntro="It's worth seeking assessment if you're experiencing any of the following:"
	symptomsList={[
		"Ongoing pelvic pain in the lower abdomen, groin, or genitals",
		"Urinary issues such as urgency, frequency, or difficulty emptying",
		"Leaking following prostate surgery",
		"Bowel issues such as constipation or difficulty controlling wind",
		"Pain during or after ejaculation",
		"Discomfort with cycling or sitting for long periods",
	]}
	treatmentHeading="How we treat"
	treatmentHighlight="pelvic health"
	treatmentIntro="Your plan is built around your symptoms and goals, and may include:"
	treatmentList={[
		"Pelvic health assessment to understand your symptoms",
		"Exercises to improve control, coordination, or relaxation of the pelvic floor",
		"Advice on bladder and bowel habits",
		"Treatment to reduce muscle tension and pain",
		"Support with returning to exercise and normal activities",
		"Education and reassurance throughout recovery",
	]}
	whoHeading="Who we"
	whoHighlight="help"
	whoList={[
		"Men recovering from prostate or bladder surgery",
		"Those dealing with ongoing pelvic pain",
		"Cyclists and active individuals with pelvic discomfort",
		"Office workers affected by prolonged sitting",
		"Men of all ages experiencing bladder or bowel symptoms",
	]}
	faqs={[
		{ q: "What happens during an appointment?", a: "We start with a detailed and confidential discussion, followed by an assessment based on your symptoms." },
		{ q: "Can you help after prostate surgery?", a: "Yes. we help you regain bladder control and confidence through targeted rehab." },
		{ q: "Is treatment confidential?", a: "Absolutely. All appointments are private and handled with discretion." },
		{ q: "Can physiotherapy help with pelvic pain?", a: "Yes. many pelvic pain conditions are linked to muscle tension and can improve with the right treatment." },
		{ q: "Do I need a referral?", a: "No, you can book directly. If using insurance, your provider may require one." },
	]}
/>
